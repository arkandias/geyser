{
  "name": "@geyser/client",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:app": "vue-tsc --noEmit -p tsconfig.app.json",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:app",
    "codegen": "graphql-codegen",
    "codegen:schema": "graphql-codegen --config codegen.schema.ts"
  },
  "dependencies": {
    "@geyser/shared": "workspace:*",
    "@urql/core": "^6.0.3",
    "@urql/exchange-auth": "^3.0.0",
    "@urql/vue": "^2.1.1",
    "axios": "^1.18.1",
    "dompurify": "^3.4.11",
    "driver.js": "^1.6.0",
    "graphql": "^17.0.1",
    "marked": "^18.0.5",
    "papaparse": "^5.5.4",
    "quasar": "^2.20.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@graphql-codegen/schema-ast": "^6.0.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@quasar/vite-plugin": "^1.12.0",
    "@types/papaparse": "^5.5.2",
    "@urql/devtools": "^2.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "glob": "^13.0.6",
    "happy-dom": "^20.10.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.100.0",
    "vite": "^8.1.0",
    "vite-plugin-compression2": "^2.5.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
