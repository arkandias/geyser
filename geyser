###############################################################################
# 1. HEADER SECTION
###############################################################################

# Exit on any error
set -e

# Help text function
show_help() {
    cat <<EOF
Geyser Administration Script

Usage: geyser [OPTIONS] COMMAND

Commands:
  init          Initialize Geyser (create volumes, apply migrations and metadata)
  start         Start Geyser containers
  stop          Stop Geyser containers
  restart       Restart Geyser containers (equivalent to stop then start)
  update        Update Geyser containers (pull and build images)
  reset         Reset Geyser (delete volumes and start fresh)
  backup        Backup databases and Keycloak realm
  restore       Restore from a previous backup
  help          Show this help message

Options:
  -h, --help    Show this help message
  --dev         Use development configuration
  --prod        Use production configuration
  --log-level   Set logging level (DEBUG|INFO|WARN|ERROR)
  --bypass-auth Start only db and hasura (development mode only)

Examples:
  geyser init --dev                Initialize Geyser in development mode
  geyser start --dev --bypass-auth Start with direct database access
  geyser start --prod             Start Geyser in production mode
  geyser backup --log-level DEBUG Create a backup with debug logging

For more information, see: https://gitlab.univ-lille.fr/julien.hauseux/geyser-backend
EOF
}

###############################################################################
# 2. CONFIGURATION AND ENVIRONMENT
###############################################################################

# Default configurations
: "${GEYSER_DIR:=$(dirname "${0}")}"
LOG_FILE="./geyser.log"
LOG_LEVEL="INFO"
BYPASS_AUTH=false

# Logging functions
log() {
    local level="${1^^}"
    level="${level:-INFO}"
    local message="${2}"
    local timestamp
    timestamp=$(date +'%Y-%m-%d %H:%M:%S')

    local -A log_levels=(
        [ERROR]=1
        [WARN]=2
        [INFO]=3
        [DEBUG]=4
    )

    if [[ ${log_levels[${level}]:-3} -le ${log_levels[${LOG_LEVEL}]} ]]; then
        case "${level}" in
        ERROR) echo >&2 -e "\033[31m[${timestamp}] [${level}] ${message}\033[0m" ;;
        WARN) echo -e "\033[33m[${timestamp}] [${level}] ${message}\033[0m" ;;
        DEBUG) echo -e "\033[34m[${timestamp}] [${level}] ${message}\033[0m" ;;
        *) echo "[${timestamp}] [${level}] ${message}" ;;
        esac
        echo "[${timestamp}] [${level}] ${message}" >>"${LOG_FILE}"
    fi
}

error() {
    log "ERROR" "${1}"
    exit 1
}
warn() { log "WARN" "${1}"; }
info() { log "INFO" "${1}"; }
debug() { log "DEBUG" "${1}"; }

###############################################################################
# 3. CORE UTILITY FUNCTIONS
###############################################################################

validate_environment() {
    # Check and export Geyser Mode
    if [[ "${GEYSER_MODE}" != @(development|production) ]]; then
        error "Invalid mode '${GEYSER_MODE}'. Must be 'development' or 'production'.
        Use option --dev/--prod or set GEYSER_MODE environment variable"
    fi
    export GEYSER_MODE

    # Check required env files exist
    touch "${GEYSER_DIR}/.env"
    touch "${GEYSER_DIR}/.env.local"
    touch "${GEYSER_DIR}/.env.${GEYSER_MODE}"
    touch "${GEYSER_DIR}/.env.${GEYSER_MODE}.local"

    # Source env files
    . "${GEYSER_DIR}/.env"
    . "${GEYSER_DIR}/.env.local"
    # shellcheck disable=SC1090
    . "${GEYSER_DIR}/.env.${GEYSER_MODE}"
    # shellcheck disable=SC1090
    . "${GEYSER_DIR}/.env.${GEYSER_MODE}.local"

    # Check required tools are installed
    command -v docker >/dev/null 2>&1 || error "Docker is not installed"
    docker compose version >/dev/null 2>&1 || error "Docker Compose V2 is required"
    command -v jq >/dev/null 2>&1 || error "jq is required for this script"
    command -v hasura >/dev/null 2>&1 || error "hasura cli is required for this script"
    command -v psql >/dev/null 2>&1 || error "PostgreSQL client (psql) is required for this script"
    command -v pg_dump >/dev/null 2>&1 || error "PostgreSQL client (pg_dump) is required for this script"
    command -v pg_restore >/dev/null 2>&1 || error "PostgreSQL client (pg_restore) is required for this script"

    # Check required directories exist and are writable
    local required_dirs=(
        "${GEYSER_DIR}/backups"
        "${GEYSER_DIR}/certs"
        "${GEYSER_DIR}/nginx/templates"
    )

    for dir in "${required_dirs[@]}"; do
        ensure_directory "${dir}"
    done

    # Check required environment variables
    # Variables always required
    local always_required=(
        "POSTGRES_PASSWORD"
        "HASURA_GRAPHQL_ADMIN_SECRET"
        "SERVER_HOST"
    )

    for var in "${always_required[@]}"; do
        if [[ -z "${!var}" ]]; then
            error "Required environment variable ${var} is not set"
        fi
    done

    # Variables required unless --bypass-auth is set
    if [[ "${BYPASS_AUTH}" != "true" ]]; then
        local auth_required=(
            "POSTGRES_KC_PASSWORD"
            "KEYCLOAK_ADMIN_PASSWORD"
        )

        for var in "${auth_required[@]}"; do
            if [[ -z "${!var}" ]]; then
                error "Required environment variable ${var} is not set (required when authentication is enabled)"
            fi
        done
    elif [[ "${GEYSER_MODE}" == "production" ]]; then
        error "Cannot use --bypass-auth in production mode"
    fi
}

ensure_directory() {
    local dir="${1}"
    if [[ ! -d "${dir}" ]]; then
        mkdir -p "${dir}" || error "Cannot create directory: ${dir}"
    fi
}

show_configuration() {
    info "Current configuration:"
    info "- Mode: ${GEYSER_MODE}"
    info "- Log level: ${LOG_LEVEL}"
    info "- Server host: ${SERVER_HOST}"
    info "- Log file: ${LOG_FILE}"
    [[ "${BYPASS_AUTH}" == "true" ]] && info "- Authentication bypass: ENABLED"
}

###############################################################################
# 4. SERVICE MANAGEMENT FUNCTIONS
###############################################################################

# Docker Compose wrapper
compose() {
    if [[ ${GEYSER_MODE} == "production" ]]; then
        docker compose \
            --env-file "${GEYSER_DIR}"/.env \
            --env-file "${GEYSER_DIR}"/.env.production \
            --env-file "${GEYSER_DIR}"/.env.local \
            --env-file "${GEYSER_DIR}"/.env.production.local \
            -f "${GEYSER_DIR}"/compose.yaml \
            -f "${GEYSER_DIR}"/compose.prod.yaml \
            "$@"
    else
        docker compose \
            --env-file "${GEYSER_DIR}"/.env \
            --env-file "${GEYSER_DIR}"/.env.development \
            --env-file "${GEYSER_DIR}"/.env.local \
            --env-file "${GEYSER_DIR}"/.env.development.local \
            -f "${GEYSER_DIR}"/compose.yaml \
            "$@"
    fi
}

# Keycloak management functions
kc() {
    compose exec keycloak /opt/keycloak/bin/kc.sh "$@"
}

kc_run() {
    KC_CMD="$*" compose -f "${GEYSER_DIR}"/compose.kc-run.yaml up keycloak
}

kcadm() {
    login=false
    for arg in "$@"; do
        shift
        case "$arg" in
        --login)
            login=true
            ;;
        *)
            set -- "$@" "$arg"
            ;;
        esac
    done

    if [[ "$login" == true ]]; then
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh config credentials \
            --server http://localhost:8080 --realm master --user admin --password "$KEYCLOAK_ADMIN_PASSWORD"
    fi

    if [[ $# -ne 0 ]]; then
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh "$@"
    fi
}

# Hasura wrapper
hasura() {
    command hasura --project "${GEYSER_DIR}"/hasura --admin-secret "${HASURA_GRAPHQL_ADMIN_SECRET}" "$@"
}

###############################################################################
# 5. HEALTH CHECK AND MONITORING
###############################################################################

wait_until_healthy() {
    info "Waiting for service ${1} to become healthy..."
    local health
    health=$(compose ps "${1}" --format json | jq '.Health')
    while [[ "${health}" != "\"healthy\"" ]]; do
        if [[ "${health}" == "\"unhealthy\"" ]]; then
            error "Service ${1} is unhealthy"
        fi
        if [[ -z "${health}" ]]; then
            error "Service ${1} stopped"
        fi
        sleep 1
        health=$(compose ps "${1}" --format json | jq '.Health')
    done
    info "Done"
}

wait_until_exit() {
    info "Waiting for service ${1} to exit..."
    while [[ -n $(compose ps -q "${1}") ]]; do
        sleep 1
    done
    container_id=$(compose ps -aq "${1}")
    if [[ -n "${container_id}" ]]; then
        exit_code=$(docker inspect --format='{{.State.ExitCode}}' "${container_id}")
    fi
    if [[ ${exit_code} -eq 0 ]]; then
        info "Done"
    else
        warn "${1} exited with code ${exit_code}"
    fi
}

###############################################################################
# 6. COMMAND HANDLERS
###############################################################################

handle_init() {
    compose up -d keycloak
    wait_until_healthy keycloak
    kcadm --login
    kcadm update realms/master -s attributes.frontendUrl=http://localhost:8080
    compose up -d
    wait_until_healthy hasura
    hasura migrate apply --database-name default
    hasura seed apply --database-name default
    hasura metadata apply
}

handle_start() {
    if ! docker volume inspect geyser_data >/dev/null 2>&1; then
        error "Volume 'geyser_data' does not exists. You must initialize Geyser first"
    fi
    if [[ "${BYPASS_AUTH}" == true ]]; then
        info "Starting without authentication (db and hasura only)..."
        compose up -d db hasura
    else
        if ! docker volume inspect geyser_data_keycloak >/dev/null 2>&1; then
            error "Volume 'geyser_data_keycloak' does not exists. You must initialize Geyser first"
        fi
        compose up -d
    fi
}

handle_backup() {
    local backup_dir="${GEYSER_DIR}/backups"
    local date
    date=$(date +%Y-%m-%d-%H-%M-%S)
    local backup_path="${backup_dir}/${date}"

    info "Creating backup in ${backup_path}"
    mkdir -p "${backup_path}"

    info "Backing up Keycloak realm..."
    kc_run export --dir "/opt/keycloak/data/backups/${date}/" --realm geyser || error "Failed to backup Keycloak"

    info "Backing up Geyser database..."
    compose exec -e PGPASSWORD="${POSTGRES_PASSWORD}" db \
        pg_dump -U postgres -h localhost -p 5432 -d geyser -Fc -f "/backups/geyser_${date}.dump" || error "Failed to backup Geyser database"

    info "Backing up Keycloak database..."
    compose exec -e PGPASSWORD="${POSTGRES_KC_PASSWORD}" db_keycloak \
        pg_dump -U postgres -h localhost -p 5432 -d keycloak -Fc -f "/backups/keycloak_${date}.dump" || error "Failed to backup Keycloak database"

    info "Backup completed successfully"
}

###############################################################################
# 7. MAIN EXECUTION
###############################################################################

main() {
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case "${1}" in
        -h | --help)
            show_help
            exit 0
            ;;
        --dev)
            GEYSER_MODE=development
            ;;
        --prod)
            GEYSER_MODE=production
            ;;
        --log-level)
            if [[ "${2^^}" =~ ^(DEBUG|INFO|WARN|ERROR)$ ]]; then
                LOG_LEVEL="${2^^}"
                shift 2
            else
                error "Option --log-level requires one of: DEBUG, INFO, WARN, ERROR"
            fi
            ;;
        --bypass-auth)
            BYPASS_AUTH=true
            shift
            ;;
        *)
            break
            ;;
        esac
        shift
    done

    # Validate environment and configuration
    validate_environment

    # Show current configuration
    show_configuration

    # Execute command
    case "${1}" in
    init) handle_init ;;
    start) handle_start ;;
    stop) compose down ;;
    restart) compose down && compose up -d ;;
    update)
        compose pull
        compose build
        info "Geyser has been updated. You must now restart Geyser"
        ;;
    reset)
        compose down -v
        info "Geyser has been reset. You must now initialize Geyser"
        ;;
    backup) handle_backup ;;
    restore) handle_restore ;;
    *) error "Unknown command: ${1}. Try 'geyser --help' for usage information." ;;
    esac
}

# Execute main function
main "$@"
