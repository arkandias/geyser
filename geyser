###############################################################################
# 1. HEADER SECTION
###############################################################################

# Exit on any error
set -e

# Help text function
show_help() {
    cat <<EOF
Geyser Administration Script

Usage: geyser [OPTIONS] COMMAND

Core Commands:
  init          Initialize a fresh Geyser installation
  start         Start all Geyser services
  stop          Stop all Geyser services
  restart       Restart all Geyser services
  update        Update all Geyser services
  reset         Delete all data and reset to a clean state

Data Operations:
  backup        Create a backup of PostgreSQL databases
  restore       Restore databases from a previous backup
  realms-export Export Keycloak realms configuration (requires services restart)
  realms-import Import Keycloak realms configuration (requires services restart)

Configuration:
  configure     Set up shell configuration for Geyser
  auto-complete Install auto-completion for bash or zsh

Utility:
  help          Show this help message

Options:
  -h, --help    Show this help message
  --dev         Use development configuration
  --prod        Use production configuration
  --log-level   Set logging level (DEBUG|INFO|WARN|ERROR)
  --bypass-auth Start only db and hasura (development mode only)

Examples:
  # Initialize in development mode
  geyser --dev init

  # Start in production
  geyser --prod start

  # Create a backup with debug logging
  geyser backup --log-level DEBUG

  # Update with detailed output
  geyser update --log-level DEBUG

  # Development mode with direct database access
  geyser --dev start --bypass-auth

  # Export realms configuration
  geyser realms-export

Note: Some commands require setting environment variables in .env files.
For more information, see: https://github.com/arkandias/geyser-backend
EOF
}

###############################################################################
# 2. CONFIGURATION AND ENVIRONMENT
###############################################################################

: "${GEYSER_DIR:=$(dirname "$0")}"
: "${GEYSER_MODE:=production}"
: "${GEYSER_LOG_LEVEL:=2}"
: "${GEYSER_BYPASS_AUTH:=false}"

DB_BACKUP_DIR="${GEYSER_DIR}/db/backups"
KC_BACKUP_DIR="${GEYSER_DIR}/keycloak/backups"
LOG_DIR="${GEYSER_DIR}/logs"
LOG_FILE="${LOG_DIR}/geyser.log"

mkdir -p "${DB_BACKUP_DIR}"
mkdir -p "${KC_BACKUP_DIR}"
mkdir -p "${LOG_DIR}"

show_configuration() {
    if [[ -n "$1" ]]; then
        info "$1"
    else
        info "Geyser configuration:"
    fi
    info "* Directory: ${GEYSER_DIR}"
    info "* Mode: ${GEYSER_MODE}"
    info "* Log level: ${GEYSER_LOG_LEVEL}"
    if [[ "${GEYSER_MODE}" == "development" ]]; then
        info "* Bypass authentication: ${GEYSER_BYPASS_AUTH}"
    fi
}

save_configuration() {
    local configuration
    local rc_files=(
        "${HOME}/.bashrc" # for Bash users
        "${HOME}/.zshrc"  # for Zsh users
    )
    local rc_file
    local rc_updated=false

    info "Generating configuration..."
    configuration=$(
        cat <<EOF
# BEGIN Geyser configuration
export GEYSER_DIR="${GEYSER_DIR}"
export GEYSER_MODE="${GEYSER_MODE}"
export GEYSER_LOG_LEVEL="${GEYSER_LOG_LEVEL}"
export GEYSER_BYPASS_AUTH="${GEYSER_BYPASS_AUTH}"
# END Geyser configuration
EOF
    )

    for rc_file in "${rc_files[@]}"; do
        if [[ -f "${rc_file}" ]]; then
            info "Updating ${rc_file}..."
            debug "Removing existing configuration block..."
            sed_i '/# BEGIN Geyser configuration/,/# END Geyser configuration/d' "${rc_file}"

            debug "Cleaning up empty lines..."
            while [ "$(tail -n 1 "${rc_file}" | grep -v '^$')" = "" ]; do
                # shellcheck disable=SC2016
                sed_i -e '$d' "${rc_file}"
            done

            debug "Writing new configuration..."
            {
                echo ""
                echo "${configuration}"
                echo ""
            } >>"${rc_file}"
            rc_updated=true

            success "Configuration saved successfully to ${rc_file}"
        fi
    done

    if [[ ! "${rc_updated}" = true ]]; then
        warn "No shell configuration files found (looked for ${HOME}/.bashrc and ${HOME}/.zshrc)"
    fi
}

validate_environment() {
    debug "Validating environment..."

    check_required_tools

    # Check Geyser Mode
    if [[ "${GEYSER_MODE}" != "development" && "${GEYSER_MODE}" != "production" ]]; then
        error "Invalid mode '${GEYSER_MODE}'. Must be 'development' or 'production'.
        Use option --dev/--prod or set GEYSER_MODE environment variable."
    fi

    # Check or create env files
    touch "${GEYSER_DIR}/.env"
    touch "${GEYSER_DIR}/.env.local"
    touch "${GEYSER_DIR}/.env.${GEYSER_MODE}"
    touch "${GEYSER_DIR}/.env.${GEYSER_MODE}.local"

    # Source env files
    . "${GEYSER_DIR}/.env"
    . "${GEYSER_DIR}/.env.local"
    # shellcheck disable=SC1090
    . "${GEYSER_DIR}/.env.${GEYSER_MODE}"
    # shellcheck disable=SC1090
    . "${GEYSER_DIR}/.env.${GEYSER_MODE}.local"
}

check_required_tools() {
    debug "Checking required tools..."
    command -v jq >/dev/null 2>&1 || error "jq is required for this script"
    command -v docker >/dev/null 2>&1 || error "Docker is not installed"
    docker compose version >/dev/null 2>&1 || error "Docker Compose V2 is required for this script"
    command -v hasura >/dev/null 2>&1 || error "Hasura CLI is required for this script"
    command -v psql >/dev/null 2>&1 || error "PostgreSQL client (psql) is required for this script"
    command -v pg_dump >/dev/null 2>&1 || error "PostgreSQL client (pg_dump) is required for this script"
    command -v pg_restore >/dev/null 2>&1 || error "PostgreSQL client (pg_restore) is required for this script"
}

###############################################################################
# 3. LOGGING
###############################################################################

log_level() {
    case "$1" in
    ERROR) echo 4 ;;
    WARN) echo 3 ;;
    INFO | SUCCESS) echo 2 ;;
    DEBUG) echo 1 ;;
    esac
}

print_level() {
    case "$1" in
    4) echo "ERROR" ;;
    3) echo "WARN" ;;
    2) echo "INFO" ;;
    1) echo "DEBUG" ;;
    esac
}

log() {
    local level="$1"
    local message="$2"
    local timestamp
    timestamp=$(date +'%Y-%m-%d %H:%M:%S')

    if [ "$(log_level "${level}")" -ge "${GEYSER_LOG_LEVEL}" ]; then
        case "${level}" in
        ERROR) echo >&2 -e "\033[31m[${timestamp}] [${level}] ${message}\033[0m" ;;
        SUCCESS) echo -e "\033[32m[${timestamp}] [${level}] ${message}\033[0m" ;;
        WARN) echo -e "\033[33m[${timestamp}] [${level}] ${message}\033[0m" ;;
        DEBUG) echo -e "\033[34m[${timestamp}] [${level}] ${message}\033[0m" ;;
        INFO) echo "[${timestamp}] [${level}] ${message}" ;;
        esac
    fi

    echo "[${timestamp}] [${level}] ${message}" >>"${LOG_FILE}"
}

error() {
    log "ERROR" "$1"
    exit 1
}
success() { log "SUCCESS" "$1"; }
warn() { log "WARN" "$1"; }
info() { log "INFO" "$1"; }
debug() { log "DEBUG" "$1"; }

###############################################################################
# 4. CORE UTILITY FUNCTIONS
###############################################################################

# Cross-platform wrapper for sed in-place editing (handles Linux/macOS differences)
sed_i() {
    case "$(uname)" in
    "Linux") sed -i "$@" ;;
    "Darwin") sed -i '' "$@" ;;
    *) error "Unsupported operating system (requires Linux or macOS)" ;;
    esac
}

# Displays a prompt and stores user input in global INPUT variable
prompt() {
    local message="$1"
    INPUT= # global

    echo -n "${message} "
    debug "Prompt: ${message}"

    read -r INPUT
    debug "Input: ${INPUT}"
}

# Prompts for yes/no confirmation with optional default (returns true/false)
confirm() {
    local message="$1"
    local default="$2"

    if [[ "${default}" == "y" ]]; then
        prompt "${message} [Y/n]"
        [[ ! "${INPUT}" =~ ^[Nn]$ ]]
    else
        prompt "${message} [y/N]"
        [[ "${INPUT}" =~ ^[Yy]$ ]]
    fi
}

# Prompts user to select a backup directory and stores result in global SELECTED_BACKUP variable
select_backup() {
    local backup_path="$1"
    local prompt_text="$2"
    local backups=()
    local backup
    SELECTED_BACKUP= # global

    for backup in "${backup_path}"/*; do
        if [[ -d "${backup}" ]]; then
            backups+=("${backup##*/}")
        fi
    done

    if ((${#backups[@]} == 0)); then
        error "No backups found"
    fi

    while true; do
        prompt "${prompt_text} (1-${#backups[@]}):"

        if [[ ! "${INPUT}" =~ ^[0-9]+$ ]]; then
            warn "Please enter a number"
            continue
        fi

        if ! ((INPUT >= 1 && INPUT <= ${#backups[@]})); then
            warn "Please enter a number between 1 and ${#backups[@]}"
            continue
        fi

        SELECTED_BACKUP="${backups[INPUT - 1]}"
        return
    done
}

###############################################################################
# 5. SERVICE MANAGEMENT FUNCTIONS
###############################################################################

# Docker Compose wrapper
compose() {
    if [[ ${GEYSER_MODE} == "production" ]]; then
        docker compose \
            --env-file "${GEYSER_DIR}"/.env \
            --env-file "${GEYSER_DIR}"/.env.production \
            --env-file "${GEYSER_DIR}"/.env.local \
            --env-file "${GEYSER_DIR}"/.env.production.local \
            -f "${GEYSER_DIR}"/compose.yaml \
            -f "${GEYSER_DIR}"/compose.prod.yaml \
            "$@"
    elif [[ ${GEYSER_BYPASS_AUTH} == "true" ]]; then
        docker compose \
            --env-file "${GEYSER_DIR}"/.env \
            --env-file "${GEYSER_DIR}"/.env.development \
            --env-file "${GEYSER_DIR}"/.env.local \
            --env-file "${GEYSER_DIR}"/.env.development.local \
            -f "${GEYSER_DIR}"/compose.yaml \
            -f "${GEYSER_DIR}"/compose.bypass-auth.yaml \
            "$@"
    else
        docker compose \
            --env-file "${GEYSER_DIR}"/.env \
            --env-file "${GEYSER_DIR}"/.env.development \
            --env-file "${GEYSER_DIR}"/.env.local \
            --env-file "${GEYSER_DIR}"/.env.development.local \
            -f "${GEYSER_DIR}"/compose.yaml \
            "$@"
    fi
}

# Keycloak management functions
kc() {
    compose exec keycloak /opt/keycloak/bin/kc.sh "$@"
}
kc_run() {
    GEYSER_BYPASS_AUTH="false" KC_CMD="$*" compose -f compose.kc-run.yaml up keycloak
}
kcadm() {
    local login=false
    local arg

    for arg in "$@"; do
        shift
        case "${arg}" in
        --login)
            login=true
            ;;
        *)
            set -- "$@" "${arg}"
            ;;
        esac
    done

    if [[ "${login}" == true ]]; then
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh config credentials \
            --server http://localhost:8080 --realm master --user admin --password "$KEYCLOAK_ADMIN_PASSWORD"
    fi

    if [[ $# -ne 0 ]]; then
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh "$@"
    fi
}

# Hasura CLI wrapper
hasura() {
    command hasura --project "${GEYSER_DIR}"/hasura --admin-secret "${HASURA_GRAPHQL_ADMIN_SECRET}" "$@"
}

wait_until_healthy() {
    local service=$1
    local timeout=${2:-300} # 5 minutes default timeout
    local start_time
    start_time=$(date +%s)

    info "Waiting for service ${service} to become healthy..."
    while true; do
        local current_time
        current_time=$(date +%s)
        if ((current_time - start_time > timeout)); then
            error "Timeout waiting for ${service} to become healthy"
        fi

        local health
        health=$(compose ps "${service}" --format json | jq '.Health')

        case "${health}" in
        "\"healthy\"")
            info "Service ${service} is healthy"
            return 0
            ;;
        "\"unhealthy\"")
            error "Service ${service} is unhealthy"
            ;;
        "")
            error "Service ${service} stopped unexpectedly"
            ;;
        esac

        sleep 1
    done
}

###############################################################################
# 6. COMMAND HANDLERS
###############################################################################

handle_init() {
    info "Starting initialization process..."

    if docker volume inspect geyser_data >/dev/null 2>&1 ||
        docker volume inspect geyser_data_keycloak >/dev/null 2>&1; then
        warn "Existing data volumes found (this may cause conflicts). You should reset Geyser first."
        if ! confirm "Initialize anyway?"; then
            info "Initialization cancelled. Please reset Geyser first with: 'geyser reset'."
            return
        fi
    fi

    info "Starting databases..."
    compose up -d db_keycloak db

    info "Starting keycloak..."
    wait_until_healthy db_keycloak
    compose up -d

    info "Initializing Hasura database..."
    wait_until_healthy db
    compose exec -e PGPASSWORD="${POSTGRES_PASSWORD}" db psql -U postgres -d geyser -f /db/schema.sql
    compose exec -e PGPASSWORD="${POSTGRES_PASSWORD}" db psql -U postgres -d geyser -f /db/init.sql

    info "Starting Hasura..."
    compose up -d hasura

    info "Applying Hasura metadata..."
    wait_until_healthy hasura
    hasura metadata apply

    if [[ ${GEYSER_MODE} == "production" ]]; then
        info "Starting nginx..."
        compose up -d
        wait_until_healthy hasura
    fi

    success "Initialization completed successfully"
}

handle_start() {
    info "Starting services..."

    if ! docker volume inspect geyser_data >/dev/null 2>&1 ||
        ! docker volume inspect geyser_data_keycloak >/dev/null 2>&1; then
        warn "Missing data volumes. You should initialize Geyser first."
        if ! confirm "Start anyway?"; then
            info "Initialization cancelled. Please initialize Geyser first with: 'geyser init'."
            return
        fi
    fi

    compose up -d

    success "All services started successfully"
}

handle_stop() {
    info "Stopping all services..."

    compose down

    success "All services stopped successfully"
}

handle_restart() {
    info "Restarting all services..."

    compose down
    compose up -d

    success "All services restarted successfully"
}

handle_update() {
    info "Starting update process..."

    if [[ -n $(compose ps -q) ]]; then
        warn "Warning: There are running services that need to be stopped for the update."
        if ! confirm "Would you like to stop them now?"; then
            info "Update cancelled. Please stop services first with: 'geyser stop'."
            return
        fi
        compose down
    fi

    info "Updating Docker images..."
    compose pull
    compose build --pull --no-cache

    info "Starting services with updated images..."
    compose up -d

    info "Cleaning up old images..."
    docker image prune -f

    success "Update completed successfully"
}

handle_reset() {
    info "Starting reset process..."

    warn "This will completely reset your Geyser installation"
    info "Note: Backup files will be preserved"
    if ! confirm "Are you sure you want to proceed?"; then
        info "Reset cancelled"
        return
    fi

    info "Stopping all services and removing volumes..."
    compose down --volumes --rmi all --remove-orphans

    info "Cleaning logs..."
    rm -f "${GEYSER_DIR}/geyser.log"

    success "Reset completed successfully"
}

handle_backup() {
    local backup
    backup=$(date +%Y-%m-%d-%H-%M-%S)

    while true; do
        prompt "Enter a backup name [${backup}]:"

        if [[ -z "${INPUT}" ]]; then
            return
        fi

        if [[ "${INPUT}" =~ ^[A-Za-z0-9_-]+$ ]]; then
            backup="${INPUT}"
            return
        fi

        warn "Please enter a name using only letters, numbers, underscores, and hyphens"
    done

    local backup_path="${DB_BACKUP_DIR}/${backup}"
    mkdir -p "${backup_path}"

    info "Backing up databases in ${backup_path}:"
    info "* Backing up Keycloak database..."
    compose exec -e PGPASSWORD="${POSTGRES_KC_PASSWORD}" db_keycloak \
        pg_dump -U postgres -h localhost -p 5433 -Fc -f "/backups/${backup}/keycloak.dump"

    info "* Backing up Geyser database..."
    compose exec -e PGPASSWORD="${POSTGRES_PASSWORD}" db \
        pg_dump -U postgres -h localhost -p 5432 -Fc -f "/backups/${backup}/geyser.dump"

    success "Backup completed successfully in ${backup_path}"
}

handle_restore() {
    if [[ -n $(compose ps -q) ]]; then
        warn "There are running services that need to be stopped for the restore."
        if ! confirm "Would you like to stop them now?"; then
            info "Restore cancelled. Please stop services first with: 'geyser stop'."
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    select_backup "${DB_BACKUP_DIR}" "Select a backup to restore"
    local backup_path="${DB_BACKUP_DIR}/${SELECTED_BACKUP}"

    info "Starting databases..."
    compose up -d db_keycloak db

    info "Restoring databases:"
    info "* Restoring Keycloak database..."
    if [[ -f "${backup_path}/keycloak.dump" ]]; then
        wait_until_healthy db_keycloak
        compose exec -e PGPASSWORD="${POSTGRES_KC_PASSWORD}" db_keycloak \
            pg_restore -U postgres -h localhost -p 5433 --clean --if-exists -v "/backups/${backup}/keycloak.dump"
    else
        warn "Found no backup for Keycloak database in ${backup}"
    fi

    info "* Restoring Geyser database..."
    if [[ -f "${backup_path}/geyser.dump" ]]; then
        wait_until_healthy db
        compose exec -e PGPASSWORD="${POSTGRES_PASSWORD}" db \
            pg_restore -U postgres -h localhost -p 5432 --clean --if-exists -v "/backups/${backup}/geyser.dump"
    else
        warn "Found no backup for Geyser database in ${backup}"
    fi

    info "Stopping all services..."
    compose down

    success "Restore completed successfully"
}

handle_realms_export() {
    if [[ -n $(compose ps -q) ]]; then
        warn "There are running services that need to be stopped for realms export."
        if ! confirm "Would you like to stop them now?"; then
            info "Realm export cancelled. Please stop services first with: 'geyser stop'."
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    local backup
    backup=$(date +%Y-%m-%d-%H-%M-%S)

    while true; do
        prompt "Enter an export name [${backup}]:"

        if [[ -z "${INPUT}" ]]; then
            return
        fi

        if [[ "${INPUT}" =~ ^[A-Za-z0-9_-]+$ ]]; then
            backup="${INPUT}"
            return
        fi

        warn "Please enter a name using only letters, numbers, underscores, and hyphens"
    done

    local backup_path="${KC_BACKUP_DIR}/${backup}"
    mkdir -p "${backup_path}"

    info "Exporting Keycloak realms in ${backup_path}..."
    kc_run export --dir "/opt/keycloak/data/backups/${backup}"

    success "Realm export completed successfully in ${backup_path}"
}

handle_realms_import() {
    if [[ -n $(compose ps -q) ]]; then
        warn "There are running services that need to be stopped for realms import."
        if ! confirm "Would you like to stop them now?"; then
            info "Realm import cancelled. Please stop services first with: 'geyser stop'."
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    select_backup "${KC_BACKUP_DIR}" "Select an export to import"
    local backup_path="${KC_BACKUP_DIR}/${SELECTED_BACKUP}"

    info "Importing Keycloak realms..."
    kc_run import --dir "/opt/keycloak/data/backups/${backup}"

    success "Realm import completed successfully"
}

handle_configure() {
    info "Configuring Geyser environment..."

    prompt "Geyser installation directory [${GEYSER_DIR}]:"
    if [[ -n ${INPUT} ]]; then
        if [[ -d "${INPUT}" ]]; then
            GEYSER_DIR="${INPUT%/}"
        else
            warn "${INPUT} is not a directory, keeping current value (${GEYSER_DIR})"
        fi
    fi

    info "Geyser mode:"
    info "1) development"
    info "2) production"
    prompt "Your choice [${GEYSER_MODE}]:"
    if [[ -n "${INPUT}" ]]; then
        case "${INPUT}" in
        1) GEYSER_MODE="development" ;;
        2) GEYSER_MODE="production" ;;
        *) warn "Invalid choice, keeping current value (${GEYSER_MODE})" ;;
        esac
    fi

    info "Log level:"
    info "1) DEBUG"
    info "2) INFO"
    info "3) WARN"
    info "4) ERROR"
    prompt "Your choice [$(print_level "${GEYSER_LOG_LEVEL}")]:"
    if [[ -n "${INPUT}" ]]; then
        case "${INPUT}" in
        1 | 2 | 3 | 4) GEYSER_LOG_LEVEL="${INPUT}" ;;
        *) warn "Invalid choice, keeping current value ($(print_level "${GEYSER_LOG_LEVEL}"))" ;;
        esac
    fi

    if [[ "${GEYSER_MODE}" == "development" ]]; then
        info "Bypass authentication:"
        info "1) false"
        info "2) true"
        prompt "Your choice [${GEYSER_BYPASS_AUTH}]:"
        if [[ -n "${INPUT}" ]]; then
            case "${INPUT}" in
            1) GEYSER_BYPASS_AUTH="false" ;;
            2) GEYSER_BYPASS_AUTH="true" ;;
            *) warn "Invalid choice, keeping current value (${GEYSER_BYPASS_AUTH})" ;;
            esac
        fi
    fi

    show_configuration "New Geyser configuration:"

    if confirm "Save configuration?" "y"; then
        save_configuration
    fi
}

handle_auto_complete() {
    info "Setting up shell auto-completion..."

    info "Select shell type:"
    info "1) Bash"
    info "2) Zsh (using oh-my-zsh)"
    prompt "Your choice [leave empty to abort]:"
    case "${INPUT}" in
    1)
        local completion_dir="/etc/bash_completion.d"

        if [[ ! -d "${completion_dir}" ]]; then
            error "Bash completion directory not found: ${completion_dir}"
        fi

        info "Installing Bash completion script..."
        if ! sudo cp "${GEYSER_DIR}/scripts/completion/geyser" "${completion_dir}/"; then
            error "Failed to install completion script"
        fi
        ;;

    2)
        local completion_dir="${HOME}/.oh-my-zsh/completions"

        if [[ ! -d "${completion_dir}" ]]; then
            if ! confirm "Zsh completion directory not found. Create it?"; then
                error "Zsh completion directory not found: ${completion_dir}"
            fi
            mkdir -p "${completion_dir}"
        fi

        info "Installing Zsh completion script..."
        if ! cp "${GEYSER_DIR}/scripts/completion/_geyser" "${completion_dir}/"; then
            error "Failed to install completion script"
        fi
        ;;

    *)
        warn "Auto-completion installation cancelled"
        return
        ;;
    esac

    success "Auto-completion installed successfully"
    info "Please restart your shell to enable completion"
}

###############################################################################
# 7. MAIN EXECUTION
###############################################################################

main() {
    debug "Entering main loop..."

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
        -h | --help)
            show_help
            exit 0
            ;;
        --dev)
            GEYSER_MODE=development
            shift
            ;;
        --prod)
            GEYSER_MODE=production
            shift
            ;;
        --log-level)
            GEYSER_LOG_LEVEL="$(log_level "$2")"
            if [ "${GEYSER_LOG_LEVEL}" -eq 0 ]; then
                error "Option --log-level must be one of: DEBUG, INFO, WARN, ERROR"
            fi
            shift 2
            ;;
        --bypass-auth)
            if [[ "${GEYSER_MODE}" == "production" ]]; then
                warn "Cannot use option --bypass-auth in production mode (ignored)"
            fi
            GEYSER_BYPASS_AUTH=true
            shift
            ;;
        -*)
            error "Unknown option: $1. Try 'geyser --help' for usage information."
            ;;
        *)
            break
            ;;
        esac
    done

    # Validate environment and configuration
    validate_environment

    # Show current configuration
    show_configuration

    # Execute command
    case "$1" in
    # Core operations
    init) handle_init ;;
    start) handle_start ;;
    stop) handle_stop ;;
    restart) handle_restart ;;
    update) handle_update ;;
    reset) handle_reset ;;

    # Data operations
    backup) handle_backup ;;
    restore) handle_restore ;;
    realms-export) handle_realms_export ;;
    realms-import) handle_realms_import ;;

    # Configuration
    configure) handle_configure ;;
    auto-complete) handle_auto_complete ;;

    # Utility
    help) show_help ;;

    *)
        error "Unknown command: $1. Try 'geyser --help' for usage information."
        ;;
    esac
}

# Execute main function
main "$@"
