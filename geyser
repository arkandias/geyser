# 1. HEADER SECTION
###############################################################################

# Exit on any error
set -e

# Help text function
show_help() {
    cat <<EOF
Geyser Administration Script

Usage: geyser [OPTIONS] COMMAND

Core Commands:
  init          Initialize a fresh Geyser installation (migrations and configuration)
  start         Start all Geyser services
  stop          Stop all Geyser services
  restart       Restart all Geyser services

Update Commands:
  update        Safely update services with migrations and backups
  force-update  Quickly rebuild and update all services (no safety checks)

Data Operations:
  backup        Create a backup of PostgreSQL databases
  restore       Restore databases from a previous backup
  reset         Delete all data and reset to a clean state
  realm-export  Export Keycloak realms configuration (requires service restart)
  realm-import  Import Keycloak realms configuration (requires service restart)

Utility:
  help          Show this help message

Options:
  -h, --help    Show this help message
  --dev         Use development configuration
  --prod        Use production configuration
  --log-level   Set logging level (DEBUG|INFO|WARN|ERROR)
  --bypass-auth Start only db and hasura (development mode only)

Examples:
  # Initialize in development mode
  geyser --dev init

  # Start in production
  geyser --prod start

  # Create a backup with debug logging
  geyser backup --log-level DEBUG

  # Update with detailed output
  geyser update --log-level DEBUG

  # Development mode with direct database access
  geyser --dev start --bypass-auth

  # Export realm configuration
  geyser realm-export

Note: Some commands require setting environment variables in .env files.
For more information, see: https://github.com/arkandias/geyser-backend
EOF
}

###############################################################################
# 2. LOGGING
###############################################################################

# Logging configuration
LOG_FILE="./geyser.log"
LOG_LEVEL="INFO"

# Logging functions
log() {
    local level="${1^^}"
    level="${level:-INFO}"
    local message="${2}"
    local timestamp
    timestamp=$(date +'%Y-%m-%d %H:%M:%S')

    local -A log_levels=(
        [ERROR]=1
        [WARN]=2
        [INFO]=3
        [DEBUG]=4
    )

    if [[ ${log_levels[${level}]:-3} -le ${log_levels[${LOG_LEVEL}]} ]]; then
        case "${level}" in
        ERROR) echo >&2 -e "\033[31m[${timestamp}] [${level}] ${message}\033[0m" ;;
        WARN) echo -e "\033[33m[${timestamp}] [${level}] ${message}\033[0m" ;;
        DEBUG) echo -e "\033[34m[${timestamp}] [${level}] ${message}\033[0m" ;;
        *) echo "[${timestamp}] [${level}] ${message}" ;;
        esac
        echo "[${timestamp}] [${level}] ${message}" >>"${LOG_FILE}"
    fi
}

error() {
    log "ERROR" "${1}"
    exit 1
}
warn() { log "WARN" "${1}"; }
info() { log "INFO" "${1}"; }
debug() { log "DEBUG" "${1}"; }

###############################################################################
# 3. CONFIGURATION AND ENVIRONMENT
###############################################################################

# Default configuration
: "${GEYSER_DIR:=$(dirname "${0}")}"
BYPASS_AUTH=false

show_configuration() {
    info "Current configuration:"
    info "- Mode: ${GEYSER_MODE}"
    info "- Log level: ${LOG_LEVEL}"
    info "- Server host: ${SERVER_HOST}"
    info "- Log file: ${LOG_FILE}"
    [[ "${BYPASS_AUTH}" == "true" ]] && info "- Authentication bypass: ENABLED"
}

validate_environment() {
    check_required_tools

    # Check and export Geyser Mode
    if [[ "${GEYSER_MODE}" != @(development|production) ]]; then
        error "Invalid mode '${GEYSER_MODE}'. Must be 'development' or 'production'.
        Use option --dev/--prod or set GEYSER_MODE environment variable"
    fi
    export GEYSER_MODE

    # Check or create env files
    touch "${GEYSER_DIR}/.env"
    touch "${GEYSER_DIR}/.env.local"
    touch "${GEYSER_DIR}/.env.${GEYSER_MODE}"
    touch "${GEYSER_DIR}/.env.${GEYSER_MODE}.local"

    # Source env files
    . "${GEYSER_DIR}/.env"
    . "${GEYSER_DIR}/.env.local"
    # shellcheck disable=SC1090
    . "${GEYSER_DIR}/.env.${GEYSER_MODE}"
    # shellcheck disable=SC1090
    . "${GEYSER_DIR}/.env.${GEYSER_MODE}.local"
}

check_required_tools() {
    command -v jq >/dev/null 2>&1 || error "jq is required for this script"
    command -v docker >/dev/null 2>&1 || error "Docker is not installed"
    docker compose version >/dev/null 2>&1 || error "Docker Compose V2 is required for this script"
    command -v hasura >/dev/null 2>&1 || error "Hasura CLI is required for this script"
    command -v psql >/dev/null 2>&1 || error "PostgreSQL client (psql) is required for this script"
    command -v pg_dump >/dev/null 2>&1 || error "PostgreSQL client (pg_dump) is required for this script"
    command -v pg_restore >/dev/null 2>&1 || error "PostgreSQL client (pg_restore) is required for this script"
}

###############################################################################
# 4. CORE UTILITY FUNCTIONS
###############################################################################

# User interaction functions
prompt() {
    echo -n "$1 "
}

confirm() {
    local message="$1"
    local default="${2:-n}" # Default to 'n' if not specified

    if [[ "$default" == "y" ]]; then
        prompt "$message [Y/n]"
    else
        prompt "$message [y/N]"
    fi

    read -r response

    if [[ "$default" == "y" ]]; then
        [[ ! "$response" =~ ^[Nn]$ ]]
    else
        [[ "$response" =~ ^[Yy]$ ]]
    fi
}

notice() {
    echo "$1"
}

# Function to list backups sorted by date (most recent first)
list_backups() {
    local backup_dir="$1"
    local found=false
    local -a backups=()

    # Collect all backup directories matching our date pattern
    for backup in "${backup_dir}"/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-[0-9][0-9]; do
        # Check if the glob expanded to an actual directory
        if [[ -d "$backup" ]]; then
            # Get just the directory name without the path
            backup="${backup##*/}"
            # Validate the format explicitly
            if [[ "$backup" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2}$ ]]; then
                backups+=("$backup")
                found=true
            fi
        fi
    done

    if [[ "$found" == "false" ]]; then
        error "No backups found"
    fi

    # Sort backups by date (most recent first)
    printf '%s\n' "${backups[@]}" | sort -r
}

###############################################################################
# 5. SERVICE MANAGEMENT FUNCTIONS
###############################################################################

# Docker Compose wrapper
compose() {
    if [[ ${GEYSER_MODE} == "production" ]]; then
        docker compose \
            --env-file "${GEYSER_DIR}"/.env \
            --env-file "${GEYSER_DIR}"/.env.production \
            --env-file "${GEYSER_DIR}"/.env.local \
            --env-file "${GEYSER_DIR}"/.env.production.local \
            -f "${GEYSER_DIR}"/compose.yaml \
            -f "${GEYSER_DIR}"/compose.prod.yaml \
            "$@"
    else
        docker compose \
            --env-file "${GEYSER_DIR}"/.env \
            --env-file "${GEYSER_DIR}"/.env.development \
            --env-file "${GEYSER_DIR}"/.env.local \
            --env-file "${GEYSER_DIR}"/.env.development.local \
            -f "${GEYSER_DIR}"/compose.yaml \
            "$@"
    fi
}

# Keycloak management functions
kc() {
    compose exec keycloak /opt/keycloak/bin/kc.sh "$@"
}

kc_run() {
    KC_CMD="$*" compose -f "${GEYSER_DIR}"/compose.kc-run.yaml up keycloak
}

kcadm() {
    login=false
    for arg in "$@"; do
        shift
        case "$arg" in
        --login)
            login=true
            ;;
        *)
            set -- "$@" "$arg"
            ;;
        esac
    done

    if [[ "$login" == true ]]; then
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh config credentials \
            --server http://localhost:8080 --realm master --user admin --password "$KEYCLOAK_ADMIN_PASSWORD"
    fi

    if [[ $# -ne 0 ]]; then
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh "$@"
    fi
}

# Hasura CLI wrapper
hasura() {
    command hasura --project "${GEYSER_DIR}"/hasura --admin-secret "${HASURA_GRAPHQL_ADMIN_SECRET}" "$@"
}

# Service health monitoring
wait_until_healthy() {
    local service=$1
    local timeout=${2:-300} # 5 minutes default timeout
    local start_time
    start_time=$(date +%s)

    info "Waiting for service ${service} to become healthy..."
    while true; do
        local current_time
        current_time=$(date +%s)
        if ((current_time - start_time > timeout)); then
            error "Timeout waiting for ${service} to become healthy"
        fi

        local health
        health=$(compose ps "${service}" --format json | jq '.Health')

        case "${health}" in
        "\"healthy\"")
            info "Service ${service} is healthy"
            return 0
            ;;
        "\"unhealthy\"")
            error "Service ${service} is unhealthy"
            ;;
        "")
            error "Service ${service} stopped unexpectedly"
            ;;
        esac

        sleep 1
    done
}

###############################################################################
# 6. COMMAND HANDLERS
###############################################################################

handle_init() {
    info "Starting initialization process..."

    # Check if volumes exist
    if docker volume inspect geyser_data >/dev/null 2>&1 ||
        docker volume inspect geyser_data_keycloak >/dev/null 2>&1; then
        notice "Warning: Existing data volumes found. This may cause conflicts."
        if ! confirm "Initialize anyway?"; then
            notice "If you want to start fresh, use: geyser reset"
            return
        fi
    fi

    # 1. Start databases first
    info "Starting databases..."
    compose up -d db db_keycloak
    wait_until_healthy db
    wait_until_healthy db_keycloak

    # 2. Initialize Hasura database
    info "Initializing Hasura database..."
    hasura migrate apply --database-name default
    hasura seed apply --database-name default
    hasura metadata apply

    # 3. Import Keycloak realms using standalone import
    info "Importing Keycloak realms..."
    # Stop any running Keycloak instance first
    compose stop keycloak || true
    # Run import
    KC_CMD="import \
        --dir /opt/keycloak/data/import \
        --override true" compose -f "${GEYSER_DIR}"/compose.kc-run.yaml run --rm keycloak || error "Failed to import Keycloak realms"

    # 4. Start Keycloak normally to configure it
    info "Starting Keycloak..."
    compose up -d keycloak
    wait_until_healthy keycloak

    # 5. Configure both realms
    info "Configuring Keycloak realms..."
    kcadm --login

    # Configure master realm
    info "- Configuring master realm..."
    if [[ ${GEYSER_MODE} == "production" ]]; then
        frontend_url="https://${SERVER_HOST}"
    else
        frontend_url="http://localhost:8080"
    fi

    kcadm update realms/master -s "attributes.frontendUrl=${frontend_url}"

    # Configure geyser realm
    info "- Configuring geyser realm..."
    if [[ ${GEYSER_MODE} == "production" ]]; then
        frontend_url="https://${SERVER_HOST}/auth"
        admin_url="http://localhost:8080/auth"
    else
        frontend_url="http://localhost:8080/auth"
        admin_url="http://localhost:8080/auth"
    fi

    kcadm update realms/geyser \
        -s "attributes.frontendUrl=${frontend_url}" \
        -s "attributes.adminUrl=${admin_url}"

    # 6. Start remaining services
    info "Starting remaining services..."
    compose up -d

    info "Initialization completed successfully"
}

handle_start() {
    info "Starting services..."

    if [[ "${BYPASS_AUTH}" == "true" ]]; then
        info "Starting in bypass auth mode (db and hasura only)..."
        compose up -d db hasura
        wait_until_healthy db
        wait_until_healthy hasura
    else
        compose up -d
        wait_until_healthy db
        wait_until_healthy db_keycloak
        wait_until_healthy keycloak
        wait_until_healthy hasura
        if [[ "${GEYSER_MODE}" == "production" ]]; then
            wait_until_healthy web
        fi
    fi

    info "All services started successfully"
}

handle_update() {
    info "Starting update process..."

    # 1. Check if there are running containers
    if [[ -n $(compose ps -q) ]]; then
        notice "There are running services that need to be stopped for the update."
        if ! confirm "Would you like to stop them now?"; then
            notice "Update cancelled. Please stop services first with: geyser stop"
            return
        fi
        compose down
    fi

    # 2. Backup before update
    notice "It's recommended to backup before updating."
    if confirm "Would you like to create a backup?" "y"; then
        info "Creating pre-update backup..."
        handle_backup || error "Backup failed, aborting update"
    fi

    # 3. Update images
    info "Updating Docker images..."

    # Pull latest versions of base images
    info "- Pulling base images..."
    compose pull db db_keycloak hasura || error "Failed to pull base images"

    # Build custom images
    info "- Building custom images..."
    compose build --pull keycloak web || error "Failed to build custom images"

    # 4. Apply migrations if any
    info "Checking for migrations..."

    # Start databases only
    compose up -d db db_keycloak
    wait_until_healthy db
    wait_until_healthy db_keycloak

    # Apply Hasura migrations if any exist
    if [[ -d "${GEYSER_DIR}/hasura/migrations" ]]; then
        info "- Applying Hasura migrations..."
        hasura migrate apply --database-name default || error "Failed to apply Hasura migrations"
        hasura metadata apply || error "Failed to apply Hasura metadata"
    else
        info "- No Hasura migrations found"
    fi

    # Check for Keycloak updates
    if [[ -d "${GEYSER_DIR}/keycloak/templates" ]]; then
        info "- Updating Keycloak configuration..."
        KC_CMD="import \
            --dir /opt/keycloak/data/import \
            --override true" compose -f "${GEYSER_DIR}"/compose.kc-run.yaml run --rm keycloak || error "Failed to update Keycloak configuration"
    fi

    # 5. Start services with new images
    info "Starting services with updated images..."
    compose up -d

    # 6. Cleanup
    info "Cleaning up old images..."
    docker image prune -f

    info "Update completed successfully"

    # Show post-update notices
    notice ""
    notice "Update complete! Some important notes:"
    notice "- Please verify that all services are running correctly"
    notice "- Check the application logs for any warnings or errors"
    notice "- If you experience any issues, you can restore the backup"
    notice "  using: geyser restore"
    if [[ ${GEYSER_MODE} == "production" ]]; then
        notice "- Remember to check SSL certificate expiration"
    fi
}

handle_force_update() {
    info "Starting forced update..."

    compose down
    compose pull
    compose build --pull --no-cache
    compose up -d

    docker image prune -f

    info "Forced update completed"
    notice "Note: This was a forced update. Please check everything is working correctly."
}

# Database backup/restore functions
handle_backup() {
    local backup_dir="${GEYSER_DIR}/backups"
    local date
    date=$(date +%Y-%m-%d-%H-%M-%S)
    local backup_path="${backup_dir}/${date}"

    info "Creating backup in ${backup_path}"
    mkdir -p "${backup_path}"

    info "Backing up databases..."
    info "- Backing up Geyser database..."
    compose exec -e PGPASSWORD="${POSTGRES_PASSWORD}" db \
        pg_dump -U postgres -h localhost -p 5432 -d geyser -Fc \
        -f "/backups/${date}/geyser.dump" || error "Failed to backup Geyser database"

    info "- Backing up Keycloak database..."
    compose exec -e PGPASSWORD="${POSTGRES_KC_PASSWORD}" db_keycloak \
        pg_dump -U postgres -h localhost -p 5432 -d keycloak -Fc \
        -f "/backups/${date}/keycloak.dump" || error "Failed to backup Keycloak database"

    info "Backup completed successfully in ${backup_path}"
}

handle_restore() {
    local backup_dir="${GEYSER_DIR}/backups"

    # List available backups
    info "Available backups:"
    list_backups "${backup_dir}"

    # Prompt for backup selection
    echo -n "Enter backup date to restore (YYYY-MM-DD-HH-MM-SS): "
    read -r backup_date

    local backup_path="${backup_dir}/${backup_date}"
    if [[ ! -d "${backup_path}" ]]; then
        error "Backup ${backup_date} not found"
    fi

    # Stop all services before restore
    info "Stopping all services..."
    compose down

    # Start databases
    info "Starting databases..."
    compose up -d db db_keycloak
    wait_until_healthy db
    wait_until_healthy db_keycloak

    info "Restoring databases..."
    info "- Restoring Geyser database..."
    compose exec -e PGPASSWORD="${POSTGRES_PASSWORD}" db \
        pg_restore -U postgres -h localhost -p 5432 -d geyser --clean --if-exists \
        "/backups/${backup_date}/geyser.dump" || error "Failed to restore Geyser database"

    info "- Restoring Keycloak database..."
    compose exec -e PGPASSWORD="${POSTGRES_KC_PASSWORD}" db_keycloak \
        pg_restore -U postgres -h localhost -p 5432 -d keycloak --clean --if-exists \
        "/backups/${backup_date}/keycloak.dump" || error "Failed to restore Keycloak database"

    info "Starting all services..."
    compose up -d

    info "Restore completed successfully"
}

handle_reset() {
    info "Starting reset process..."

    notice "WARNING: This will completely reset your Geyser installation:"
    notice "- All databases will be deleted"
    notice "- All Docker resources will be cleaned"
    notice "- All configuration will be reset"
    notice "- All logs will be cleared"
    notice "Note: Backup files in ${GEYSER_DIR}/backups will be preserved"

    if ! confirm "Are you sure you want to proceed?"; then
        info "Reset cancelled"
        return
    fi

    info "Stopping all services and removing volumes..."
    compose down -v

    info "Cleaning up Docker resources..."
    # Remove orphaned volumes
    docker volume ls -qf "name=geyser" | xargs -r docker volume rm

    # Remove old images
    docker images "geyser_*" -q | xargs -r docker rmi
    docker images "keycloak" -q | xargs -r docker rmi

    # Clean build cache and dangling images
    docker builder prune -f
    docker image prune -f

    # Remove unused networks
    docker network prune -f --filter "until=1h"

    info "Cleaning project files..."
    # Clean logs
    rm -f "${GEYSER_DIR}/geyser.log"
    rm -f "${GEYSER_DIR}/hasura/hasura.log"

    # Clean Hasura metadata and migrations
    rm -rf "${GEYSER_DIR}/hasura/migrations"
    rm -rf "${GEYSER_DIR}/hasura/metadata/migrations"

    # Clean temporary files
    find "${GEYSER_DIR}" -name "*.tmp" -type f -delete
    find "${GEYSER_DIR}" -name "*.bak" -type f -delete
    find "${GEYSER_DIR}" -name ".DS_Store" -type f -delete

    info "Reset completed successfully"

    if confirm "Would you like to initialize Geyser now?" "y"; then
        handle_init
    else
        notice "You can initialize later using: geyser init"
    fi
}

# Keycloak realm import/export functions
handle_realm_export() {
    local backup_dir="${GEYSER_DIR}/backups"
    local date
    date=$(date +%Y-%m-%d-%H-%M-%S)
    local backup_path="${backup_dir}/${date}"

    info "Creating export directory in ${backup_path}"
    mkdir -p "${backup_path}"

    # Stop all services
    info "Stopping all services..."
    compose down

    info "Exporting Keycloak realm..."
    # Run Keycloak in export mode only
    KC_CMD="export \
        --dir /opt/keycloak/data/backups/${date} \
        --realm geyser \
        --users realm \
        --groups \
        --clients \
        --realm-roles \
        --client-roles" compose -f "${GEYSER_DIR}"/compose.kc-run.yaml run --rm keycloak || error "Failed to export Keycloak realm"

    # Ensure proper permissions
    compose run --rm keycloak chown -R root:root "/opt/keycloak/data/backups/${date}"
    compose run --rm keycloak chmod -R u=rw,g=r,o=r "/opt/keycloak/data/backups/${date}"

    info "Starting all services..."
    compose up -d

    info "Realm export completed successfully in ${backup_path}"
}

handle_realm_import() {
    local backup_dir="${GEYSER_DIR}/backups"

    # List available exports using same function as backup listing
    info "Available realm exports:"
    list_backups "${backup_dir}"

    # Prompt for export selection
    echo -n "Enter export date to import (YYYY-MM-DD-HH-MM-SS): "
    read -r export_date

    # Validate input format
    if [[ ! "${export_date}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{2}$ ]]; then
        error "Invalid date format. Expected: YYYY-MM-DD-HH-MM-SS"
    fi

    local export_path="${backup_dir}/${export_date}"
    if [[ ! -d "${export_path}" ]]; then
        error "Export ${export_date} not found"
    fi

    # Stop all services
    info "Stopping all services..."
    compose down

    info "Importing Keycloak realm..."
    # Run Keycloak in import mode only
    KC_CMD="import \
        --dir /opt/keycloak/data/backups/${export_date} \
        --override true" compose -f "${GEYSER_DIR}"/compose.kc-run.yaml run --rm keycloak || error "Failed to import Keycloak realm"

    info "Starting all services..."
    compose up -d

    info "Realm import completed successfully"
}

###############################################################################
# 7. MAIN EXECUTION
###############################################################################

main() {
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case "${1}" in
        -h | --help)
            show_help
            exit 0
            ;;
        --dev)
            GEYSER_MODE=development
            shift
            ;;
        --prod)
            GEYSER_MODE=production
            shift
            ;;
        --log-level)
            if [[ "${2^^}" =~ ^(DEBUG|INFO|WARN|ERROR)$ ]]; then
                LOG_LEVEL="${2^^}"
                shift 2
            else
                error "Option --log-level requires one of: DEBUG, INFO, WARN, ERROR"
            fi
            ;;
        --bypass-auth)
            if [[ "${GEYSER_MODE}" == "production" ]]; then
                error "Cannot use --bypass-auth in production mode"
            fi
            BYPASS_AUTH=true
            shift
            ;;
        *)
            break
            ;;
        esac
    done

    # Validate environment and configuration
    validate_environment

    # Show current configuration
    show_configuration

    # Execute command
    case "${1}" in
    # Core operations
    init)
        handle_init
        ;;
    start)
        handle_start
        ;;
    stop)
        info "Stopping all services..."
        compose down
        ;;
    restart)
        info "Restarting all services..."
        compose down
        compose up -d
        ;;

    # Update operations
    update) handle_update ;;
    force-update)
        handle_force_update
        ;;

    # Data operations
    backup)
        handle_backup
        ;;
    restore)
        handle_restore
        ;;
    reset)
        handle_reset
        ;;
    realm-export)
        handle_realm_export
        ;;
    realm-import)
        handle_realm_import
        ;;

    # Utility
    help)
        show_help
        ;;
    *)
        error "Unknown command: ${1}. Try 'geyser --help' for usage information"
        ;;
    esac
}

# Execute main function
main "$@"
