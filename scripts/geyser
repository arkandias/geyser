# License: GNU AGPL v3.0
#######################################

###############################################################################
# 1. HEADER SECTION
###############################################################################

readonly VERSION="1.0.0"

# Exit the script immediately if any command fails
set -e

# Help text function
show_help() {
    cat <<EOF
Geyser Administration Script v${VERSION}

Usage: geyser [OPTIONS] COMMAND

Core Commands:
  init              Initialize a fresh Geyser installation
  start             Start all Geyser services
  stop              Stop all Geyser services
  restart           Restart all Geyser services
  update            Update all Geyser services
  reset             Delete all data and reset to a clean state

Data Operations:
  backup            Create a backup of PostgreSQL databases
  restore           Restore databases from a previous backup
  realms-export     Export Keycloak realms configuration (requires services restart)
  realms-import     Import Keycloak realms configuration (requires services restart)
  sync-keycloak     Synchronize Keycloak users with active teachers

Options:
  -h, --help        Show this help message
  -v, --version     Show version information
  --dev             Use development configuration
  --prod            Use production configuration
  --bypass-auth     Start only db and hasura (development mode only)
  --log-level       Set logging level (DEBUG|INFO|WARN|ERROR)
  --show-config     Display current configuration 
  --configure       Configure Geyser settings
  --autocomplete    Install autocomplete for bash or zsh (using oh-my-zsh)

For more information, see: https://github.com/arkandias/geyser-backend
EOF
}

###############################################################################
# 2. ENVIRONMENT AND CONFIGURATION
###############################################################################

#------------------------------------------------------------------------------
# Directory Setup
#------------------------------------------------------------------------------

readonly ROOT_DIR
ROOT_DIR="$(dirname "$0")"
readonly DB_BACKUP_DIR="${ROOT_DIR}/postgres/backups"
readonly KC_BACKUP_DIR="${ROOT_DIR}/keycloak/backups"
readonly LOG_DIR="${ROOT_DIR}/logs"
readonly LOG_FILE="${LOG_DIR}/geyser.log"

#------------------------------------------------------------------------------
# Environment Variables
#------------------------------------------------------------------------------

MODE="production"   # Operational mode (development/production)
BYPASS_AUTH="false" # Skip authentication for development
LOG_LEVEL="INFO"    # Log level in text form
LOG_LEVEL_NUM=2     # Log level as number (1=DEBUG, 2=INFO, 3=WARN, 4=ERROR)

#------------------------------------------------------------------------------
# Command Line Options
#------------------------------------------------------------------------------

OPT_DEV=false          # --dev flag for development mode
OPT_PROD=false         # --prod flag for production mode
OPT_BYPASS_AUTH=false  # --bypass-auth flag to skip authentication
OPT_LOG_LEVEL=         # --log-level flag value
OPT_SHOW_CONFIG=false  # --show-config flag to display configuration
OPT_CONFIGURE=false    # --configure flag to set up environment
OPT_AUTOCOMPLETE=false # --autocomplete flag for shell completion

#------------------------------------------------------------------------------
# Dependencies
#------------------------------------------------------------------------------

check_dependencies() {
    debug "Checking dependencies..."
    command -v docker >/dev/null 2>&1 || error "Docker is not installed"
    local docker_version
    docker_version=$(docker version --format '{{.Server.Version}}' 2>/dev/null | cut -d'.' -f1)
    if [[ -z "${docker_version}" ]]; then
        error "Docker daemon is not running"
    elif [[ "${docker_version}" -lt 25 ]]; then
        error "Docker Engine version 25.0 or higher is required (current: ${docker_version})"
    fi
    docker compose version >/dev/null 2>&1 || error "Docker Compose V2 is required"
    command -v hasura >/dev/null 2>&1 || error "Hasura CLI is not installed.
You can install it with: curl -L https://github.com/hasura/graphql-engine/raw/stable/cli/get.sh | bash"
}

#------------------------------------------------------------------------------
# Environment Validation & Loading
#------------------------------------------------------------------------------

load_environment() {
    debug "Loading environment..."
    debug "Root directory: ${ROOT_DIR}"

    # Create required directories
    mkdir -p "${DB_BACKUP_DIR}"
    mkdir -p "${KC_BACKUP_DIR}"
    mkdir -p "${LOG_DIR}"

    # Load env files
    touch "${ROOT_DIR}/.env"
    touch "${ROOT_DIR}/.env.local"
    . "${ROOT_DIR}/.env"
    . "${ROOT_DIR}/.env.local"

    # Set MODE
    if [[ "${OPT_DEV}" == "true" && "${OPT_PROD}" == "true" ]]; then
        error "Invalid options: --dev and --prod cannot be used together"
    fi
    if [[ "${OPT_DEV}" == "true" && "${MODE}" != "development" ]]; then
        MODE="development"
        debug "Mode overridden with --dev option"
    fi
    if [[ "${OPT_PROD}" == "true" && "${MODE}" != "production" ]]; then
        MODE="production"
        debug "Mode overridden with --prod option"
    fi
    if [[ "${MODE}" != "development" && "${MODE}" != "production" ]]; then
        error "Invalid mode '${MODE}' (must be 'development' or 'production').
Use options --dev/--prod or set MODE environment variable."
    fi
    debug "Mode set to '${MODE}'"

    # Load mode-specific env files
    touch "${ROOT_DIR}/.env.${MODE}"
    touch "${ROOT_DIR}/.env.${MODE}.local"
    # shellcheck disable=SC1090
    . "${ROOT_DIR}/.env.${MODE}"
    # shellcheck disable=SC1090
    . "${ROOT_DIR}/.env.${MODE}.local"

    # Set BYPASS_AUTH
    if [[ "${OPT_BYPASS_AUTH}" != "true" ]]; then
        BYPASS_AUTH="${OPT_BYPASS_AUTH}"
        debug "Bypass authentication setting overridden with --bypass-auth option"
    fi
    if [[ "${BYPASS_AUTH}" != "true" && "${BYPASS_AUTH}" != "false" ]]; then
        error "Invalid bypass authentication setting '${BYPASS_AUTH}' (must be 'true' or 'false').
Use option --bypass-auth or set BYPASS_AUTH environment variable."
    fi
    if [[ "${MODE}" == "production" && "${BYPASS_AUTH}" == "true" ]]; then
        warn "Authentication is required in production mode (ignored)"
        BYPASS_AUTH="false"
    fi
    debug "Bypass authentication set to '${BYPASS_AUTH}'"

    # Set LOG_LEVEL
    if [[ "${OPT_LOG_LEVEL}" != "${LOG_LEVEL}" ]]; then
        LOG_LEVEL="${OPT_LOG_LEVEL}"
        debug "Log level overridden with --log-level option"
    fi
    if ! LOG_LEVEL_NUM="$(log_level "${LOG_LEVEL}")"; then
        error "Invalid log level '${LOG_LEVEL}' (must be 'DEBUG', 'INFO', 'WARN', or 'ERROR').
Use option --log-level or set LOG_LEVEL environment variable."
    fi
    debug "Log level set to '${LOG_LEVEL}'"
}

#------------------------------------------------------------------------------
# Configuration Display & Management
#------------------------------------------------------------------------------

show_configuration() {
    info "Geyser configuration:"
    info "* Directory: ${ROOT_DIR}"
    info "* Mode: ${MODE}"
    info "* Log level: ${LOG_LEVEL}"
    if [[ "${MODE}" == "development" ]]; then
        info "* Bypass authentication: ${BYPASS_AUTH}"
    fi
}

save_configuration() {
    local env_file="${ROOT_DIR}/.env"
    local configuration
    configuration=$(
        cat <<EOF
MODE="${MODE}"
LOG_LEVEL="${LOG_LEVEL}"
BYPASS_AUTH="${BYPASS_AUTH}"
EOF
    )

    if [[ -f "${env_file}" ]]; then
        if [[ -s "${env_file}" ]]; then
            cp "${env_file}" "${env_file}.bak"
            info "Created backup of existing configuration at ${env_file}.bak"
        else
            debug "Existing configuration file is empty, no backup needed"
        fi
    fi

    echo "${configuration}" >"${env_file}"

    success "Configuration saved successfully to ${env_file}"
}

configure() {
    info "Configuring Geyser environment..."

    info "Available modes:"
    info "1) development"
    info "2) production"
    while true; do
        prompt "Your choice [production]:"
        case "${INPUT}" in
        1 | "")
            MODE="production"
            continue
            ;;
        2)
            MODE="development"
            continue
            ;;
        *)
            warn "Invalid input: enter a number between 1 and 2"
            ;;
        esac
    done

    if [[ "${MODE}" == "development" ]]; then
        info "Bypass authentication:"
        info "1) false"
        info "2) true"
        while true; do
            prompt "Your choice [false]:"
            case "${INPUT}" in
            1 | "")
                BYPASS_AUTH="false"
                continue
                ;;
            2)
                BYPASS_AUTH="true"
                continue
                ;;
            *)
                warn "Invalid input: enter a number between 1 and 2"
                ;;
            esac
        done
    fi

    info "Log level:"
    info "1) DEBUG"
    info "2) INFO"
    info "3) WARN"
    info "4) ERROR"
    while true; do
        prompt "Your choice [INFO]:"
        case "${INPUT}" in
        1)
            LOG_LEVEL="DEBUG"
            continue
            ;;
        2 | "")
            LOG_LEVEL="INFO"
            continue
            ;;
        3)
            LOG_LEVEL="WARN"
            continue
            ;;
        4)
            LOG_LEVEL="ERROR"
            continue
            ;;
        *)
            warn "Invalid input: enter a number between 1 and 4"
            ;;
        esac
    done

    if confirm "Save configuration?" "y"; then
        save_configuration
    fi
}

#------------------------------------------------------------------------------
# Shell Completion Setup
#------------------------------------------------------------------------------

install_autocomplete() {
    info "Setting up shell autocompletion..."

    info "Available shells:"
    info "1) bash"
    info "2) zsh (using oh-my-zsh)"
    info "3) Abort"
    while true; do
        prompt "Your choice [Abort]:"
        case "${INPUT}" in
        1)
            local completion_dir="/etc/bash_completion.d"

            if [[ ! -d "${completion_dir}" ]]; then
                error "bash completion directory not found: ${completion_dir}"
            fi

            info "Installing bash completion script..."
            if ! sudo cp "${ROOT_DIR}/scripts/completion/geyser" "${completion_dir}/"; then
                error "Failed to install bash completion script"
            fi
            continue
            ;;
        2)
            local completion_dir="${HOME}/.oh-my-zsh/completions"

            if [[ ! -d "${completion_dir}" ]]; then
                if ! confirm "zsh completion directory not found. Create it?"; then
                    error "zsh completion directory not found: ${completion_dir}"
                fi
                mkdir -p "${completion_dir}"
            fi

            info "Installing zsh completion script..."
            if ! cp "${ROOT_DIR}/scripts/completion/_geyser" "${completion_dir}/"; then
                error "Failed to install zsh completion script"
            fi
            continue
            ;;
        3 | "")
            warn "Autocomplete installation cancelled"
            return
            ;;
        *)
            warn "Invalid input: enter a number between 1 and 3"
            ;;
        esac
    done

    success "Autocomplete installed successfully"
    info "Please restart your shell to enable completion"
}

###############################################################################
# 3. LOGGING
###############################################################################

log_level() {
    case "$1" in
    ERROR) echo 4 ;;
    WARN) echo 3 ;;
    INFO | SUCCESS) echo 2 ;;
    DEBUG) echo 1 ;;
    *) error "Invalid log level '${LOG_LEVEL}' (must be 'DEBUG', 'INFO', 'WARN', or 'ERROR')" ;;
    esac
}

log() {
    local level="$1"
    local message="$2"
    local timestamp
    timestamp=$(date +'%Y-%m-%d %H:%M:%S')

    if [[ "$(log_level "${level}")" -ge "${LOG_LEVEL_NUM}" ]]; then
        case "${level}" in
        ERROR) echo >&2 -e "\033[31m[${timestamp}] [${level}] ${message}\033[0m" ;;
        SUCCESS) echo -e "\033[32m[${timestamp}] [${level}] ${message}\033[0m" ;;
        WARN) echo -e "\033[33m[${timestamp}] [${level}] ${message}\033[0m" ;;
        DEBUG) echo -e "\033[34m[${timestamp}] [${level}] ${message}\033[0m" ;;
        INFO) echo -e "[${timestamp}] [${level}] ${message}" ;;
        esac
    fi

    echo "[${timestamp}] [${level}] ${message}" >>"${LOG_FILE}"
}

error() {
    log "ERROR" "$1"
    exit 1
}
success() { log "SUCCESS" "$1"; }
warn() { log "WARN" "$1"; }
info() { log "INFO" "$1"; }
debug() { log "DEBUG" "$1"; }

###############################################################################
# 4. CORE UTILITY FUNCTIONS
###############################################################################

# Displays a prompt and stores user input in global INPUT variable
prompt() {
    local message="$1"
    INPUT= # global

    echo -n "${message} "
    debug "Prompt: ${message}"

    read -r INPUT
    debug "Input: ${INPUT}"
}

# Prompts for yes/no confirmation with optional default (returns true/false)
confirm() {
    local message="$1"
    local default="$2"

    if [[ "${default}" == "y" ]]; then
        prompt "${message} [Y/n]"
        [[ ! "${INPUT}" =~ ^[Nn]$ ]]
    else
        prompt "${message} [y/N]"
        [[ "${INPUT}" =~ ^[Yy]$ ]]
    fi
}

# Prompts user to select a backup directory and stores result in global variable SELECTED_BACKUP
select_backup() {
    local backup_path="$1"
    local prompt_text="$2"
    local backups=()
    local backup
    SELECTED_BACKUP= # global

    for backup in "${backup_path}"/*; do
        if [[ -d "${backup}" ]]; then
            backups+=("${backup##*/}")
        fi
    done

    if ((${#backups[@]} == 0)); then
        error "No backups found"
    fi

    while true; do
        prompt "${prompt_text} (1-${#backups[@]}):"

        if [[ ! "${INPUT}" =~ ^[0-9]+$ ]] || ! ((INPUT >= 1 && INPUT <= ${#backups[@]})); then
            warn "Invalid input: enter a number between 1 and ${#backups[@]}"
            continue
        fi

        SELECTED_BACKUP="${backups[INPUT - 1]}"
        return
    done
}

###############################################################################
# 5. SERVICE MANAGEMENT FUNCTIONS
###############################################################################

# Docker Compose wrapper
compose() {
    if [[ ${MODE} == "production" ]]; then
        docker compose \
            --env-file "${ROOT_DIR}"/.env \
            --env-file "${ROOT_DIR}"/.env.production \
            --env-file "${ROOT_DIR}"/.env.local \
            --env-file "${ROOT_DIR}"/.env.production.local \
            -f "${ROOT_DIR}"/compose.yaml \
            -f "${ROOT_DIR}"/compose.prod.yaml \
            "$@"
    elif [[ ${BYPASS_AUTH} == "true" ]]; then
        docker compose \
            --env-file "${ROOT_DIR}"/.env \
            --env-file "${ROOT_DIR}"/.env.development \
            --env-file "${ROOT_DIR}"/.env.local \
            --env-file "${ROOT_DIR}"/.env.development.local \
            -f "${ROOT_DIR}"/compose.yaml \
            -f "${ROOT_DIR}"/compose.bypass-auth.yaml \
            "$@"
    else
        docker compose \
            --env-file "${ROOT_DIR}"/.env \
            --env-file "${ROOT_DIR}"/.env.development \
            --env-file "${ROOT_DIR}"/.env.local \
            --env-file "${ROOT_DIR}"/.env.development.local \
            -f "${ROOT_DIR}"/compose.yaml \
            "$@"
    fi
}

# Keycloak management functions
kc() {
    compose exec -T keycloak /opt/keycloak/bin/kc.sh "$@"
}
kcadm() {
    if [[ "$1" == "--login" ]]; then
        shift
        if [[ "$#" -ne 0 ]]; then
            error "No additional arguments allowed with 'kcadm --login'"
        fi
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh config credentials \
            --server http://localhost:8080 --realm master --user admin --password "${KEYCLOAK_ADMIN_PASSWORD}"
    else
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh "$@"
    fi
}
kc_run() {
    BYPASS_AUTH="false" KC_CMD="$*" compose -f compose.kc-run.yaml up keycloak
}

# Hasura CLI wrapper
hasura() {
    command hasura --project "${ROOT_DIR}"/hasura --admin-secret "${HASURA_GRAPHQL_ADMIN_SECRET}" "$@"
}

wait_until_healthy() {
    local service="$1"
    local timeout="${2:-300}" # 5 minutes default timeout
    local start_time
    start_time="$(date +%s)"

    info "Waiting for service ${service} to become healthy..."
    while true; do
        local current_time
        current_time=$(date +%s)
        if ((current_time - start_time > timeout)); then
            error "Service ${service} health check timeout"
        fi

        local health
        health=$(compose ps "${service}" --format '{{.Health}}')

        case "${health}" in
        "\"healthy\"")
            info "Service ${service} is healthy"
            return 0
            ;;
        "\"unhealthy\"")
            error "Service ${service} is unhealthy"
            ;;
        "")
            error "Service ${service} stopped unexpectedly"
            ;;
        esac

        sleep 1
    done
}

###############################################################################
# 6. COMMAND HANDLERS
###############################################################################

handle_init() {
    info "Starting initialization..."

    if docker volume inspect geyser_data >/dev/null 2>&1 ||
        docker volume inspect geyser_data_keycloak >/dev/null 2>&1; then
        warn "Existing data volumes found (this may cause conflicts). You should reset Geyser first with 'geyser reset'"
        if ! confirm "Initialize anyway?"; then
            info "Initialization cancelled: reset Geyser first with 'geyser reset'"
            return
        fi
    fi

    info "Starting databases..."
    compose up -d db_keycloak db

    info "Starting Keycloak..."
    wait_until_healthy db_keycloak
    compose up -d

    info "Initializing Hasura database..."
    wait_until_healthy db
    compose exec -T db bash -c "psql -U postgres -d geyser -f /initdb/schema.sql && psql -U postgres -d geyser -f /initdb/init.sql"

    info "Starting Hasura..."
    compose up -d hasura

    info "Applying Hasura metadata..."
    wait_until_healthy hasura
    hasura metadata apply

    if [[ ${MODE} == "production" ]]; then
        info "Starting Nginx..."
        compose up -d
        wait_until_healthy hasura
    fi

    success "Initialization completed successfully"
}

handle_start() {
    info "Starting all services..."

    if ! docker volume inspect geyser_data >/dev/null 2>&1 ||
        ! docker volume inspect geyser_data_keycloak >/dev/null 2>&1; then
        warn "Missing data volumes. You should initialize Geyser first with 'geyser init'"
        if ! confirm "Start anyway?"; then
            info "Initialization cancelled: initialize Geyser first with 'geyser init'"
            return
        fi
    fi

    compose up -d

    success "All services started successfully"
}

handle_stop() {
    info "Stopping all services..."

    compose down

    success "All services stopped successfully"
}

handle_restart() {
    info "Restarting all services..."

    compose down
    compose up -d

    success "All services restarted successfully"
}

handle_update() {
    info "Starting update..."

    if [[ -n $(compose ps -q) ]]; then
        warn "Running services need to be stopped for update"
        if ! confirm "Stop them now?"; then
            info "Update cancelled: stop services first with 'geyser stop'"
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    info "Updating Docker images..."
    compose pull
    compose build --pull --no-cache

    info "Starting all services with updated images..."
    compose up -d

    info "Cleaning up old images..."
    docker image prune -f

    success "Update completed successfully"
}

handle_reset() {
    info "Starting reset..."

    warn "This will completely reset your Geyser installation. Note: backup files will be preserved"
    if ! confirm "Are you sure you want to proceed?"; then
        info "Reset cancelled: backup Geyser first with 'geyser backup' and 'geyser realms-export'"
        return
    fi

    info "Stopping all services and cleaning up..."
    compose down --volumes --rmi all --remove-orphans

    info "Cleaning logs..."
    rm -f "${ROOT_DIR}/geyser.log"

    success "Reset completed successfully"
}

handle_backup() {
    local backup
    backup=$(date +%Y-%m-%d-%H-%M-%S)

    while true; do
        prompt "Enter a backup name [${backup}]:"

        if [[ -z "${INPUT}" ]]; then
            return
        fi

        if [[ "${INPUT}" =~ ^[A-Za-z0-9_-]+$ ]]; then
            backup="${INPUT}"
            return
        fi

        warn "Invalid input: enter a backup name using only letters, numbers, underscores, and hyphens, or leave empty to use timestamp"
    done

    local backup_path="${DB_BACKUP_DIR}/${backup}"
    mkdir -p "${backup_path}"

    info "Backing up databases in ${backup_path}:"
    info "→ Backing up Keycloak database..."
    compose exec -T db_keycloak bash -c \
        "pg_dump -U postgres -d keycloak -Fc > /backups/${backup}/keycloak.dump"
    info "→ Backing up Geyser database..."
    compose exec -T db bash -c \
        "pg_dump -U postgres -d geyser -Fc > /backups/${backup}/geyser.dump"

    success "Backup completed successfully in ${backup_path}"
}

handle_restore() {
    if [[ -n $(compose ps -q) ]]; then
        warn "Running services need to be stopped for restore"
        if ! confirm "Stop them now?"; then
            info "Restore cancelled: stop services first with 'geyser stop'"
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    select_backup "${DB_BACKUP_DIR}" "Select a backup to restore"
    local backup_path="${DB_BACKUP_DIR}/${SELECTED_BACKUP}"

    info "Starting databases..."
    compose up -d db_keycloak db

    info "Restoring databases:"
    info "→ Restoring Keycloak database..."
    if [[ -f "${backup_path}/keycloak.dump" ]]; then
        wait_until_healthy db_keycloak
        compose exec -T db_keycloak bash -c \
            "pg_restore -U postgres -d keycloak --clean --if-exists -v /backups/${SELECTED_BACKUP}/keycloak.dump"
    else
        warn "No backups found for Keycloak database in ${backup}"
    fi

    info "→ Restoring Geyser database..."
    if [[ -f "${backup_path}/geyser.dump" ]]; then
        wait_until_healthy db
        compose exec -T db bash -c \
            "pg_restore -U postgres -d geyser --clean --if-exists -v /backups/${SELECTED_BACKUP}/geyser.dump"
    else
        warn "No backups found for Geyser database in ${backup}"
    fi

    info "Stopping all services..."
    compose down

    success "Restore completed successfully"
}

handle_realms_export() {
    if [[ -n $(compose ps -q) ]]; then
        warn "Running services need to be stopped for realms export"
        if ! confirm "Stop them now?"; then
            info "Realms export cancelled: stop services first with 'geyser stop'"
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    local backup
    backup=$(date +%Y-%m-%d-%H-%M-%S)

    while true; do
        prompt "Enter an export name [${backup}]:"

        if [[ -z "${INPUT}" ]]; then
            return
        fi

        if [[ "${INPUT}" =~ ^[A-Za-z0-9_-]+$ ]]; then
            backup="${INPUT}"
            return
        fi

        warn "Invalid input: enter an export name using only letters, numbers, underscores, and hyphens, or leave empty to use timestamp"
    done

    local backup_path="${KC_BACKUP_DIR}/${backup}"
    mkdir -p "${backup_path}"

    info "Exporting Keycloak realms in ${backup_path}..."
    kc_run export --dir "/opt/keycloak/data/backups/${backup}"

    success "Realm export completed successfully in ${backup_path}"
}

handle_realms_import() {
    if [[ -n $(compose ps -q) ]]; then
        warn "Running services need to be stopped for realms import"
        if ! confirm "Stop them now?"; then
            info "Realms import cancelled: stop services first with 'geyser stop'"
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    select_backup "${KC_BACKUP_DIR}" "Select an export to import"
    local backup_path="${KC_BACKUP_DIR}/${SELECTED_BACKUP}"

    info "Importing Keycloak realms..."
    kc_run import --dir "/opt/keycloak/data/backups/${backup}"

    success "Realm import completed successfully"
}

handle_sync_keycloak() {
    info "Starting Keycloak synchronization..."

    command -v jq >/dev/null 2>&1 || error "jq is not installed.
You can install it with: 'sudo apt install jq' (Ubuntu) or 'brew install jq' (macOS)"

    info "Fetching active teachers from Geyser database..."
    local teachers active_teachers
    teachers=$(compose exec -T db bash -c \
        "psql -U postgres -d geyser -A -t -c 'SELECT json_agg(t) FROM teacher t;'")
    if [[ -z "${teachers}" ]]; then
        error "Failed to fetch teachers from Geyser database"
    fi
    active_teachers=$(echo "${teachers}" | jq -c '[.[] | select(.active==true)]')

    info "Authenticating with Keycloak..."
    kcadm --login || error "Failed to authenticate with Keycloak"

    info "Fetching Keycloak users and groups..."
    local kc_users kc_groups kc_teachers_gid kc_teachers
    kc_users=$(kcadm get users -r geyser --limit -1)
    debug "Keycloak users:\n${kc_users}"
    kc_groups=$(kcadm get groups -r geyser)
    debug "Keycloak groups:\n${kc_groups}"
    kc_teachers_gid=$(echo "${kc_groups}" | jq -r '.[] | select(.name=="Teachers") | .id')
    if [[ -z "${kc_teachers_gid}" ]]; then
        error "Group 'Teachers' does not exist in Keycloak"
    fi
    debug "Keycloak 'Teachers' Group ID: ${kc_teachers_gid}"
    kc_teachers=$(kcadm get groups/"${kc_teachers_gid}"/members -r geyser --limit -1 | jq -r '[.[] | .id]')
    debug "Keycloak teachers:\n${kc_teachers}"

    info "Creating or updating Keycloak users corresponding to active teachers in Geyser database..."
    while IFS= read -r teacher; do
        local uid firstname lastname kc_user kc_user_id
        uid=$(echo "${teacher}" | jq -r '.uid')
        firstname=$(echo "${teacher}" | jq -r '.firstname')
        lastname=$(echo "${teacher}" | jq -r '.lastname')
        kc_user=$(echo "${kc_users}" | jq --arg uid "${uid}" -c '.[] | select(.email==$uid)')
        kc_user_id=$(echo "${kc_user}" | jq -r '.id')

        if [[ -z "${kc_user_id}" ]]; then
            info "User '${uid}' not found"
            info "Creating user '${uid}'..."
            debug "User creation data: email=${uid}, firstName=${firstname}, lastName=${lastname}, and enabled=true..."
            kcadm create users -r geyser \
                -s email="${uid}" \
                -s firstName="${firstname}" \
                -s lastName="${lastname}" \
                -s enabled=true ||
                error "Failed to create user '${uid}'"
            kc_user_id=$(kcadm get users -r geyser -q email="${uid}" | jq -r '.[] | .id')
        else
            info "User '${uid}' found"
            local kc_firstname kc_lastname kc_enabled update_fields=()
            kc_firstname=$(echo "${kc_user}" | jq -r '.firstName')
            kc_lastname=$(echo "${kc_user}" | jq -r '.lastName')
            kc_enabled=$(echo "${kc_user}" | jq -r '.enabled')
            if [[ "${kc_firstname}" != "${firstname}" ]]; then
                debug "First name mismatch: remote '${kc_firstname}' != local '${firstname}'"
                update_fields+=(-s "firstName=${firstname}")
            fi
            if [[ "${kc_lastname}" != "${lastname}" ]]; then
                debug "Last name mismatch: remote '${kc_lastname}' != local '${lastname}'"
                update_fields+=(-s "lastName=${lastname}")
            fi
            if [[ "${kc_enabled}" != "true" ]]; then
                debug "Enabled status mismatch: remote '${kc_enabled}' != local 'true'"
                update_fields+=(-s "enabled=true")
            fi
            if [[ ${#update_fields[@]} -gt 0 ]]; then
                info "Updating user '${uid}'..."
                kcadm update users/"${kc_user_id}" -r geyser "${update_fields[@]}"
            fi
        fi

        if ! echo "${kc_teachers}" | jq -e --arg id "${kc_user_id}" 'contains([$id])' >/dev/null; then
            info "Adding user '${uid}' to group 'Teachers'..."
            kcadm update users/"${kc_user_id}"/groups/"${kc_teachers_gid}" -r geyser -s realm=geyser -s userId="${kc_user_id}"
        fi
    done < <(echo "${active_teachers}" | jq -c '.[]')

    info "Disabling Keycloak users not corresponding to active teachers in Geyser database..."
    while IFS= read -r kc_user; do
        local email kc_user_id
        email=$(echo "${kc_user}" | jq -r '.email')
        if echo "${active_teachers}" | jq -e --arg email "${email}" '.[] | select(.uid==$email)' >/dev/null; then
            info "User ${email} is an active teacher (ignored)"
        else
            info "Disabling user ${email}..."
            kc_user_id=$(echo "${kc_user}" | jq -r '.id')
            kcadm update kc_users/"${kc_user_id}" -r geyser -s enabled=false
        fi
    done < <(echo "${kc_users}" | jq -c '.[] | select(.enabled==true)')

    success "Keycloak synchronization completed successfully"
}

###############################################################################
# 7. MAIN EXECUTION
###############################################################################

main() {
    debug "Entering main loop..."

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
        -h | --help)
            show_help
            exit 0
            ;;
        -v | --version)
            echo "Geyser Administration Script v${VERSION}"
            exit 0
            ;;
        --dev)
            OPT_DEV=true
            shift
            ;;
        --prod)
            OPT_PROD=true
            shift
            ;;
        --bypass-auth)
            OPT_BYPASS_AUTH=true
            shift
            ;;
        --log-level)
            OPT_LOG_LEVEL="$2"
            shift 2
            ;;
        --show-config)
            OPT_SHOW_CONFIG=true
            shift
            ;;
        --configure)
            OPT_CONFIGURE=true
            shift
            ;;
        --autocomplete)
            OPT_AUTOCOMPLETE=true
            shift
            ;;
        --)
            break
            ;;
        -*)
            error "Unknown option '$1' (see 'geyser --help')"
            ;;
        *)
            break
            ;;
        esac
    done

    check_dependencies
    load_environment

    # Configure
    if [[ "${OPT_CONFIGURE}" == "true" ]]; then
        configure
    fi

    # Autocomplete
    if [[ "${OPT_AUTOCOMPLETE}" == "true" ]]; then
        install_autocomplete
    fi

    # Show current configuration
    if [[ "${OPT_SHOW_CONFIG}" == "true" ]]; then
        show_configuration
    fi

    # Execute command
    case "$1" in
    # Core operations
    init) handle_init ;;
    start) handle_start ;;
    stop) handle_stop ;;
    restart) handle_restart ;;
    update) handle_update ;;
    reset) handle_reset ;;

    # Data operations
    backup) handle_backup ;;
    restore) handle_restore ;;
    realms-export) handle_realms_export ;;
    realms-import) handle_realms_import ;;

    *)
        error "Unknown command '$1' (see 'geyser --help')"
        ;;
    esac
}

# Execute main function
main "$@"
