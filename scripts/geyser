#!/bin/bash
#######################################
# Geyser Administration Script
# Author: Julien Hauseux <julien.hauseux@univ-lille.fr>
# Version: 1.0.0
# License: GNU AGPL v3.0
#######################################

###############################################################################
# 1. HEADER SECTION
###############################################################################

readonly VERSION="1.0.0"

# Exit the script immediately if any command fails
set -e

# Help text function
show_help() {
    cat <<EOF
Geyser Administration Script v${VERSION}

Usage: geyser [OPTIONS] COMMAND

Core Commands:
  init              Initialize a fresh Geyser installation
  start             Start all Geyser services
  stop              Stop all Geyser services
  restart           Restart all Geyser services
  update            Update all Geyser services
  reset             Delete all data and reset to a clean state

Data Operations:
  backup            Create a backup of PostgreSQL databases
  restore           Restore databases from a previous backup
  realms-export     Export Keycloak realms configuration (requires services restart)
  realms-import     Import Keycloak realms configuration (requires services restart)

Options:
  -h, --help        Show this help message
  -v, --version     Show version information
  --dev             Use development configuration
  --prod            Use production configuration
  --bypass-auth     Start only db and hasura (development mode only)
  --log-level       Set logging level (DEBUG|INFO|WARN|ERROR)
  --show-config     Display current configuration 
  --configure       Configure Geyser settings
  --autocomplete    Install autocomplete for bash or zsh (using oh-my-zsh)

For more information, see: https://github.com/arkandias/geyser-backend
EOF
}

###############################################################################
# 2. ENVIRONMENT AND CONFIGURATION
###############################################################################

# Set absolute root directory for Geyser installation
readonly ROOT_DIR
ROOT_DIR="$(dirname "$0")"

# Directory paths for backups and logs
readonly DB_BACKUP_DIR="${ROOT_DIR}/db/backups"
readonly KC_BACKUP_DIR="${ROOT_DIR}/keycloak/backups"
readonly LOG_DIR="${ROOT_DIR}/logs"
readonly LOG_FILE="${LOG_DIR}/geyser.log"

# Default environment settings
MODE="production"   # Operational mode (development/production)
BYPASS_AUTH="false" # Skip authentication for development
LOG_LEVEL="INFO"    # Log level in text form
LOG_LEVEL_NUM=2     # Log level as number (1=DEBUG, 2=INFO, 3=WARN, 4=ERROR)

# Command line option flags
OPT_DEV=false          # --dev flag for development mode
OPT_PROD=false         # --prod flag for production mode
OPT_BYPASS_AUTH=false  # --bypass-auth flag to skip authentication
OPT_LOG_LEVEL=         # --log-level flag value
OPT_SHOW_CONFIG=false  # --show-config flag to display configuration
OPT_CONFIGURE=false    # --configure flag to set up environment
OPT_AUTOCOMPLETE=false # --autocomplete flag for shell completion

check_required_tools() {
    debug "Checking required tools..."
    command -v docker >/dev/null 2>&1 || error "Docker is not installed"
    local docker_version
    docker_version=$(docker version --format '{{.Server.Version}}' 2>/dev/null | cut -d'.' -f1)
    if [[ -z "${docker_version}" ]]; then
        error "Could not determine Docker Engine version. Is Docker daemon running?"
    elif [[ "${docker_version}" -lt 25 ]]; then
        error "Docker Engine version must be 25.0 or higher. Current version: $(docker version --format '{{.Server.Version}}')"
    fi
    docker compose version >/dev/null 2>&1 || error "Docker Compose V2 is required for this script"
    command -v hasura >/dev/null 2>&1 || error "Hasura CLI is required for this script.
You can install it with: curl -L https://github.com/hasura/graphql-engine/raw/stable/cli/get.sh | bash"
}

validate_environment() {
    debug "Validating environment..."
    debug "Root directory: ${ROOT_DIR}"

    # Create required directories
    mkdir -p "${DB_BACKUP_DIR}"
    mkdir -p "${KC_BACKUP_DIR}"
    mkdir -p "${LOG_DIR}"

    # Load env files
    touch "${ROOT_DIR}/.env"
    touch "${ROOT_DIR}/.env.local"
    . "${ROOT_DIR}/.env"
    . "${ROOT_DIR}/.env.local"

    # Set MODE
    if [[ "${OPT_DEV}" == "true" && "${OPT_PROD}" == "true" ]]; then
        error "Cannot use options --dev and --prod together"
    fi
    if [[ "${OPT_DEV}" == "true" && "${MODE}" != "development" ]]; then
        MODE="development"
        debug "Geyser mode overridden with --dev option"
    fi
    if [[ "${OPT_PROD}" == "true" && "${MODE}" != "production" ]]; then
        MODE="production"
        debug "Geyser mode overridden with --prod option"
    fi
    if [[ "${MODE}" != "development" && "${MODE}" != "production" ]]; then
        error "Invalid mode: '${MODE}'. Must be 'development' or 'production'.
Use option --dev/--prod or set MODE environment variable."
    fi
    debug "Mode: ${MODE}"

    # Load mode-specific env files
    touch "${ROOT_DIR}/.env.${MODE}"
    touch "${ROOT_DIR}/.env.${MODE}.local"
    # shellcheck disable=SC1090
    . "${ROOT_DIR}/.env.${MODE}"
    # shellcheck disable=SC1090
    . "${ROOT_DIR}/.env.${MODE}.local"

    # Set BYPASS_AUTH
    if [[ "${OPT_BYPASS_AUTH}" != "true" ]]; then
        BYPASS_AUTH="${OPT_BYPASS_AUTH}"
        debug "Bypass authentication setting overridden with --bypass-auth option"
    fi
    if [[ "${BYPASS_AUTH}" != "true" && "${BYPASS_AUTH}" != "false" ]]; then
        error "Invalid bypass authentication setting: '${BYPASS_AUTH}'. Must be 'true' or 'false'.
Use option --bypass-auth or set BYPASS_AUTH environment variable."
    fi
    if [[ "${MODE}" == "production" && "${BYPASS_AUTH}" == "true" ]]; then
        error "Cannot bypass authentication in production mode"
    fi
    debug "Bypass authentication setting: ${BYPASS_AUTH}"

    # Set LOG_LEVEL
    if [[ "${OPT_LOG_LEVEL}" != "${LOG_LEVEL}" ]]; then
        LOG_LEVEL="${OPT_LOG_LEVEL}"
        debug "Log level setting overridden with --log-level option"
    fi
    if ! LOG_LEVEL_NUM="$(log_level "${LOG_LEVEL}")"; then
        error "Invalid log level: '${LOG_LEVEL}'. Must be one of: DEBUG, INFO, WARN, ERROR.
Use option --log-level or set LOG_LEVEL environment variable."
    fi
    debug "Log level: ${LOG_LEVEL}"
}

show_configuration() {
    info "Geyser configuration:"
    info "* Directory: ${ROOT_DIR}"
    info "* Mode: ${MODE}"
    info "* Log level: ${LOG_LEVEL}"
    if [[ "${MODE}" == "development" ]]; then
        info "* Bypass authentication: ${BYPASS_AUTH}"
    fi
}

save_configuration() {
    local env_file="${ROOT_DIR}/.env"
    local configuration
    configuration=$(
        cat <<EOF
MODE="${MODE}"
LOG_LEVEL="${LOG_LEVEL}"
BYPASS_AUTH="${BYPASS_AUTH}"
EOF
    )

    if [[ -f "${env_file}" ]]; then
        if [[ -s "${env_file}" ]]; then
            cp "${env_file}" "${env_file}.bak"
            info "Created backup of existing configuration at ${env_file}.bak"
        else
            debug "Existing configuration file is empty, no backup needed"
        fi
    fi

    echo "${configuration}" >"${env_file}"

    success "Configuration saved successfully to ${env_file}"
}

configure() {
    info "Configuring Geyser environment..."

    info "Mode:"
    info "1) development"
    info "2) production"
    while true; do
        prompt "Your choice [production]:"
        case "${INPUT}" in
        1 | "")
            MODE="production"
            continue
            ;;
        2)
            MODE="development"
            continue
            ;;
        *)
            warn "Invalid choice"
            ;;
        esac
    done

    if [[ "${MODE}" == "development" ]]; then
        info "Bypass authentication:"
        info "1) false"
        info "2) true"
        while true; do
            prompt "Your choice [false]:"
            case "${INPUT}" in
            1 | "")
                BYPASS_AUTH="false"
                continue
                ;;
            2)
                BYPASS_AUTH="true"
                continue
                ;;
            *) warn "Invalid choice" ;;
            esac
        done
    fi

    info "Log level:"
    info "1) DEBUG"
    info "2) INFO"
    info "3) WARN"
    info "4) ERROR"
    while true; do
        prompt "Your choice [INFO]:"
        case "${INPUT}" in
        1)
            LOG_LEVEL="DEBUG"
            continue
            ;;
        2 | "")
            LOG_LEVEL="INFO"
            continue
            ;;
        3)
            LOG_LEVEL="WARN"
            continue
            ;;
        4)
            LOG_LEVEL="ERROR"
            continue
            ;;
        *)
            warn "Invalid choice"
            ;;
        esac
    done

    if confirm "Save configuration?" "y"; then
        save_configuration
    fi
}

install_autocomplete() {
    info "Setting up shell autocompletion..."

    info "Select shell type:"
    info "1) bash"
    info "2) zsh (using oh-my-zsh)"
    prompt "Your choice [leave empty to abort]:"
    case "${INPUT}" in
    1)
        local completion_dir="/etc/bash_completion.d"

        if [[ ! -d "${completion_dir}" ]]; then
            error "bash completion directory not found: ${completion_dir}"
        fi

        info "Installing bash completion script..."
        if ! sudo cp "${ROOT_DIR}/scripts/completion/geyser" "${completion_dir}/"; then
            error "Failed to install bash completion script"
        fi
        ;;
    2)
        local completion_dir="${HOME}/.oh-my-zsh/completions"

        if [[ ! -d "${completion_dir}" ]]; then
            if ! confirm "zsh completion directory not found. Create it?"; then
                error "zsh completion directory not found: ${completion_dir}"
            fi
            mkdir -p "${completion_dir}"
        fi

        info "Installing zsh completion script..."
        if ! cp "${ROOT_DIR}/scripts/completion/_geyser" "${completion_dir}/"; then
            error "Failed to install zsh completion script"
        fi
        ;;
    *)
        warn "Autocomplete installation cancelled"
        return
        ;;
    esac

    success "Autocomplete installed successfully"
    info "Please restart your shell to enable completion"
}

###############################################################################
# 3. LOGGING
###############################################################################

log_level() {
    case "$1" in
    ERROR) echo 4 ;;
    WARN) echo 3 ;;
    INFO | SUCCESS) echo 2 ;;
    DEBUG) echo 1 ;;
    *) error "Invalid log level: '$1'. Must be one of: DEBUG, INFO, WARN, ERROR" ;;
    esac
}

log() {
    local level="$1"
    local message="$2"
    local timestamp
    timestamp=$(date +'%Y-%m-%d %H:%M:%S')

    if [[ "$(log_level "${level}")" -ge "${LOG_LEVEL_NUM}" ]]; then
        case "${level}" in
        ERROR) echo >&2 -e "\033[31m[${timestamp}] [${level}] ${message}\033[0m" ;;
        SUCCESS) echo -e "\033[32m[${timestamp}] [${level}] ${message}\033[0m" ;;
        WARN) echo -e "\033[33m[${timestamp}] [${level}] ${message}\033[0m" ;;
        DEBUG) echo -e "\033[34m[${timestamp}] [${level}] ${message}\033[0m" ;;
        INFO) echo -e "[${timestamp}] [${level}] ${message}" ;;
        esac
    fi

    echo "[${timestamp}] [${level}] ${message}" >>"${LOG_FILE}"
}

error() {
    log "ERROR" "$1"
    exit 1
}
success() { log "SUCCESS" "$1"; }
warn() { log "WARN" "$1"; }
info() { log "INFO" "$1"; }
debug() { log "DEBUG" "$1"; }

###############################################################################
# 4. CORE UTILITY FUNCTIONS
###############################################################################

# Displays a prompt and stores user input in global INPUT variable
prompt() {
    local message="$1"
    INPUT= # global

    echo -n "${message} "
    debug "Prompt: ${message}"

    read -r INPUT
    debug "Input: ${INPUT}"
}

# Prompts for yes/no confirmation with optional default (returns true/false)
confirm() {
    local message="$1"
    local default="$2"

    if [[ "${default}" == "y" ]]; then
        prompt "${message} [Y/n]"
        [[ ! "${INPUT}" =~ ^[Nn]$ ]]
    else
        prompt "${message} [y/N]"
        [[ "${INPUT}" =~ ^[Yy]$ ]]
    fi
}

# Prompts user to select a backup directory and stores result in global variable SELECTED_BACKUP
select_backup() {
    local backup_path="$1"
    local prompt_text="$2"
    local backups=()
    local backup
    SELECTED_BACKUP= # global

    for backup in "${backup_path}"/*; do
        if [[ -d "${backup}" ]]; then
            backups+=("${backup##*/}")
        fi
    done

    if ((${#backups[@]} == 0)); then
        error "No backups found"
    fi

    while true; do
        prompt "${prompt_text} (1-${#backups[@]}):"

        if [[ ! "${INPUT}" =~ ^[0-9]+$ ]]; then
            warn "Please enter a number"
            continue
        fi

        if ! ((INPUT >= 1 && INPUT <= ${#backups[@]})); then
            warn "Please enter a number between 1 and ${#backups[@]}"
            continue
        fi

        SELECTED_BACKUP="${backups[INPUT - 1]}"
        return
    done
}

###############################################################################
# 5. SERVICE MANAGEMENT FUNCTIONS
###############################################################################

# Docker Compose wrapper
compose() {
    if [[ ${MODE} == "production" ]]; then
        docker compose \
            --env-file "${ROOT_DIR}"/.env \
            --env-file "${ROOT_DIR}"/.env.production \
            --env-file "${ROOT_DIR}"/.env.local \
            --env-file "${ROOT_DIR}"/.env.production.local \
            -f "${ROOT_DIR}"/compose.yaml \
            -f "${ROOT_DIR}"/compose.prod.yaml \
            "$@"
    elif [[ ${BYPASS_AUTH} == "true" ]]; then
        docker compose \
            --env-file "${ROOT_DIR}"/.env \
            --env-file "${ROOT_DIR}"/.env.development \
            --env-file "${ROOT_DIR}"/.env.local \
            --env-file "${ROOT_DIR}"/.env.development.local \
            -f "${ROOT_DIR}"/compose.yaml \
            -f "${ROOT_DIR}"/compose.bypass-auth.yaml \
            "$@"
    else
        docker compose \
            --env-file "${ROOT_DIR}"/.env \
            --env-file "${ROOT_DIR}"/.env.development \
            --env-file "${ROOT_DIR}"/.env.local \
            --env-file "${ROOT_DIR}"/.env.development.local \
            -f "${ROOT_DIR}"/compose.yaml \
            "$@"
    fi
}

# Keycloak management functions
kc() {
    compose exec keycloak /opt/keycloak/bin/kc.sh "$@"
}
kc_run() {
    BYPASS_AUTH="false" KC_CMD="$*" compose -f compose.kc-run.yaml up keycloak
}
kcadm() {
    local login=false
    local arg

    for arg in "$@"; do
        shift
        case "${arg}" in
        --login)
            login=true
            ;;
        *)
            set -- "$@" "${arg}"
            ;;
        esac
    done

    if [[ "${login}" == true ]]; then
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh config credentials \
            --server http://localhost:8080 --realm master --user admin --password "$KEYCLOAK_ADMIN_PASSWORD"
    fi

    if [[ $# -ne 0 ]]; then
        compose exec -T keycloak /opt/keycloak/bin/kcadm.sh "$@"
    fi
}

# Hasura CLI wrapper
hasura() {
    command hasura --project "${ROOT_DIR}"/hasura --admin-secret "${HASURA_GRAPHQL_ADMIN_SECRET}" "$@"
}

wait_until_healthy() {
    local service="$1"
    local timeout="${2:-300}" # 5 minutes default timeout
    local start_time
    start_time="$(date +%s)"

    info "Waiting for service ${service} to become healthy..."
    while true; do
        local current_time
        current_time=$(date +%s)
        if ((current_time - start_time > timeout)); then
            error "Timeout waiting for ${service} to become healthy"
        fi

        local health
        health=$(compose ps "${service}" --format '{{.Health}}')

        case "${health}" in
        "\"healthy\"")
            info "Service ${service} is healthy"
            return 0
            ;;
        "\"unhealthy\"")
            error "Service ${service} is unhealthy"
            ;;
        "")
            error "Service ${service} stopped unexpectedly"
            ;;
        esac

        sleep 1
    done
}

###############################################################################
# 6. COMMAND HANDLERS
###############################################################################

handle_init() {
    info "Starting initialization process..."

    if docker volume inspect geyser_data >/dev/null 2>&1 ||
        docker volume inspect geyser_data_keycloak >/dev/null 2>&1; then
        warn "Existing data volumes found (this may cause conflicts). You should reset Geyser first."
        if ! confirm "Initialize anyway?"; then
            info "Initialization cancelled. Please reset Geyser first with: geyser reset"
            return
        fi
    fi

    info "Starting databases..."
    compose up -d db_keycloak db

    info "Starting keycloak..."
    wait_until_healthy db_keycloak
    compose up -d

    info "Initializing Hasura database..."
    wait_until_healthy db
    compose exec -T db bash -c "psql -U postgres -d geyser -f /initdb/schema.sql && psql -U postgres -d geyser -f /initdb/init.sql"

    info "Starting Hasura..."
    compose up -d hasura

    info "Applying Hasura metadata..."
    wait_until_healthy hasura
    hasura metadata apply

    if [[ ${MODE} == "production" ]]; then
        info "Starting nginx..."
        compose up -d
        wait_until_healthy hasura
    fi

    success "Initialization completed successfully"
}

handle_start() {
    info "Starting services..."

    if ! docker volume inspect geyser_data >/dev/null 2>&1 ||
        ! docker volume inspect geyser_data_keycloak >/dev/null 2>&1; then
        warn "Missing data volumes. You should initialize Geyser first."
        if ! confirm "Start anyway?"; then
            info "Initialization cancelled. Please initialize Geyser first with: geyser init"
            return
        fi
    fi

    compose up -d

    success "All services started successfully"
}

handle_stop() {
    info "Stopping all services..."

    compose down

    success "All services stopped successfully"
}

handle_restart() {
    info "Restarting all services..."

    compose down
    compose up -d

    success "All services restarted successfully"
}

handle_update() {
    info "Starting update process..."

    if [[ -n $(compose ps -q) ]]; then
        warn "Warning: There are running services that need to be stopped for the update."
        if ! confirm "Would you like to stop them now?"; then
            info "Update cancelled. Please stop services first with: geyser stop"
            return
        fi
        compose down
    fi

    info "Updating Docker images..."
    compose pull
    compose build --pull --no-cache

    info "Starting services with updated images..."
    compose up -d

    info "Cleaning up old images..."
    docker image prune -f

    success "Update completed successfully"
}

handle_reset() {
    info "Starting reset process..."

    warn "This will completely reset your Geyser installation"
    info "Note: Backup files will be preserved"
    if ! confirm "Are you sure you want to proceed?"; then
        info "Reset cancelled"
        return
    fi

    info "Stopping all services and removing volumes..."
    compose down --volumes --rmi all --remove-orphans

    info "Cleaning logs..."
    rm -f "${ROOT_DIR}/geyser.log"

    success "Reset completed successfully"
}

handle_backup() {
    local backup
    backup=$(date +%Y-%m-%d-%H-%M-%S)

    while true; do
        prompt "Enter a backup name [${backup}]:"

        if [[ -z "${INPUT}" ]]; then
            return
        fi

        if [[ "${INPUT}" =~ ^[A-Za-z0-9_-]+$ ]]; then
            backup="${INPUT}"
            return
        fi

        warn "Please enter a name using only letters, numbers, underscores, and hyphens"
    done

    local backup_path="${DB_BACKUP_DIR}/${backup}"
    mkdir -p "${backup_path}"

    info "Backing up databases in ${backup_path}:"
    info "* Backing up Keycloak database..."
    compose exec -T db_keycloak bash -c \
        "pg_dump -U postgres -d keycloak -Fc > /backups/${backup}/keycloak.dump"
    info "* Backing up Geyser database..."
    compose exec -T db bash -c \
        "pg_dump -U postgres -d geyser -Fc > /backups/${backup}/geyser.dump"

    success "Backup completed successfully in ${backup_path}"
}

handle_restore() {
    if [[ -n $(compose ps -q) ]]; then
        warn "There are running services that need to be stopped for the restore."
        if ! confirm "Would you like to stop them now?"; then
            info "Restore cancelled. Please stop services first with: geyser stop"
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    select_backup "${DB_BACKUP_DIR}" "Select a backup to restore"
    local backup_path="${DB_BACKUP_DIR}/${SELECTED_BACKUP}"

    info "Starting databases..."
    compose up -d db_keycloak db

    info "Restoring databases:"
    info "* Restoring Keycloak database..."
    if [[ -f "${backup_path}/keycloak.dump" ]]; then
        wait_until_healthy db_keycloak
        compose exec -T db_keycloak bash -c \
            "pg_restore -U postgres -d keycloak --clean --if-exists -v /backups/${SELECTED_BACKUP}/keycloak.dump"
    else
        warn "Found no backup for Keycloak database in ${backup}"
    fi

    info "* Restoring Geyser database..."
    if [[ -f "${backup_path}/geyser.dump" ]]; then
        wait_until_healthy db
        compose exec -T db bash -c \
            "pg_restore -U postgres -d geyser --clean --if-exists -v /backups/${SELECTED_BACKUP}/geyser.dump"
    else
        warn "Found no backup for Geyser database in ${backup}"
    fi

    info "Stopping all services..."
    compose down

    success "Restore completed successfully"
}

handle_realms_export() {
    if [[ -n $(compose ps -q) ]]; then
        warn "There are running services that need to be stopped for realms export."
        if ! confirm "Would you like to stop them now?"; then
            info "Realm export cancelled. Please stop services first with: geyser stop"
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    local backup
    backup=$(date +%Y-%m-%d-%H-%M-%S)

    while true; do
        prompt "Enter an export name [${backup}]:"

        if [[ -z "${INPUT}" ]]; then
            return
        fi

        if [[ "${INPUT}" =~ ^[A-Za-z0-9_-]+$ ]]; then
            backup="${INPUT}"
            return
        fi

        warn "Please enter a name using only letters, numbers, underscores, and hyphens"
    done

    local backup_path="${KC_BACKUP_DIR}/${backup}"
    mkdir -p "${backup_path}"

    info "Exporting Keycloak realms in ${backup_path}..."
    kc_run export --dir "/opt/keycloak/data/backups/${backup}"

    success "Realm export completed successfully in ${backup_path}"
}

handle_realms_import() {
    if [[ -n $(compose ps -q) ]]; then
        warn "There are running services that need to be stopped for realms import."
        if ! confirm "Would you like to stop them now?"; then
            info "Realm import cancelled. Please stop services first with: geyser stop"
            return
        fi
        info "Stopping all services..."
        compose down
    fi

    select_backup "${KC_BACKUP_DIR}" "Select an export to import"
    local backup_path="${KC_BACKUP_DIR}/${SELECTED_BACKUP}"

    info "Importing Keycloak realms..."
    kc_run import --dir "/opt/keycloak/data/backups/${backup}"

    success "Realm import completed successfully"
}

###############################################################################
# 7. MAIN EXECUTION
###############################################################################

main() {
    debug "Entering main loop..."

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
        -h | --help)
            show_help
            exit 0
            ;;
        -v | --version)
            echo "Geyser Administration Script v${VERSION}"
            exit 0
            ;;
        --dev)
            OPT_DEV=true
            shift
            ;;
        --prod)
            OPT_PROD=true
            shift
            ;;
        --bypass-auth)
            OPT_BYPASS_AUTH=true
            shift
            ;;
        --log-level)
            OPT_LOG_LEVEL="$2"
            shift 2
            ;;
        --show-config)
            OPT_SHOW_CONFIG=true
            shift
            ;;
        --configure)
            OPT_CONFIGURE=true
            shift
            ;;
        --autocomplete)
            OPT_AUTOCOMPLETE=true
            shift
            ;;
        --)
            break
            ;;
        -*)
            error "Unknown option: $1. Try 'geyser --help' for usage information."
            ;;
        *)
            break
            ;;
        esac
    done

    check_required_tools
    validate_environment

    # Configure
    if [[ "${OPT_CONFIGURE}" == "true" ]]; then
        configure
    fi

    # Autocomplete
    if [[ "${OPT_AUTOCOMPLETE}" == "true" ]]; then
        install_autocomplete
    fi

    # Show current configuration
    if [[ "${OPT_SHOW_CONFIG}" == "true" ]]; then
        show_configuration
    fi

    # Execute command
    case "$1" in
    # Core operations
    init) handle_init ;;
    start) handle_start ;;
    stop) handle_stop ;;
    restart) handle_restart ;;
    update) handle_update ;;
    reset) handle_reset ;;

    # Data operations
    backup) handle_backup ;;
    restore) handle_restore ;;
    realms-export) handle_realms_export ;;
    realms-import) handle_realms_import ;;

    *)
        error "Unknown command: '$1'. Try 'geyser --help' for usage information."
        ;;
    esac
}

# Execute main function
main "$@"
